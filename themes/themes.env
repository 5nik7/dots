#!/usr/bin/env zsh

export DOTHEMES="${DOTHEMES:-$DOTS/themes}"
export THEMES="${DOTHEMES:-$DOTS/themes}"
export THEMESBIN="${THEMESBIN:-$THEMES/bin}"

declare -x dot[themes]="$DOTS/themes"
declare -xgA themes
declare -x themes[root]="${DOTHEMES:-$DOTS/themes}"
declare -x themes[bin]="${THEMESBIN:-$THEMES/bin}"

alias ".t"="cd $themes[root]"
alias ".tb"="cd $themes[bin]"

prepath "$themes[bin]"
fpath=($themes[bin] $fpath)
