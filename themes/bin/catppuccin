  sky='#99d1db'
  sapphire='#85c1dc'
  blue='#8caaee'
  lavender='#babbf1'
  text='#c6d0f5'
  subtext1='#b5bfe2'
  subtext0='#a5adce'
  overlay2='#949cbb'
  overlay1='#838ba7'
  overlay0='#737994'
  surface2='#626880'
  surface1='#51576d'
  surface0='#414559'
  base='#303446'
  mantle='#292c3c'
  crust='#232634'
}

declare -r esc=$'\033'
declare -r rst="${esc}[0m"
declare -r bold="${esc}[1m"
declare -r dim="${esc}[2m"
declare -r italic="${esc}[3m"
declare -r underline="${esc}[4m"
declare -r rev="${esc}[7m"

declare -r base_black="${esc}[30m"
declare -r base_red="${esc}[31m"
declare -r base_green="${esc}[32m"
declare -r base_yellow="${esc}[33m"
declare -r base_blue="${esc}[34m"
declare -r base_magenta="${esc}[35m"
declare -r base_cyan="${esc}[36m"
declare -r base_white="${esc}[37m"

declare sep='|'
declare caticon="󰄛"
declare block='󰄮'
declare default_flavor="mocha"
declare default_format="hex"

err() { printf "${base_red}%s %s %s${rst}\n\n" "[ERROR]" "$caticon" "$*" >&2; }
die() {
  err "$*"
  exit 1
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

cmd_exists() {
  command -v "$1" &>/dev/null
}

has -v pastel || die

chcmd() {
  "$@" &>/dev/null && "$@"
}

fg() {
  COLOR="$1"
  local r=$(chcmd pastel format rgb-r ${!COLOR})
  local g=$(chcmd pastel format rgb-g ${!COLOR})
  local b=$(chcmd pastel format rgb-b ${!COLOR})
  local fg="${esc}[38;2;${r};${g};${b}m"

  printf "%s" "$fg"
}

bg() {
  COLOR="$1"
  local r=$(chcmd pastel -m off format rgb-r ${!COLOR})
  local g=$(chcmd pastel -m off format rgb-g ${!COLOR})
  local b=$(chcmd pastel -m off format rgb-b ${!COLOR})
  local bg="${esc}[48;2;${r};${g};${b}m"

  printf "%s" "$bg"
}

tc=$(fg mauve)
bc=$(fg surface0)

logo() {
  while IFS= read -r logo; do
    echo "$logo"
  done <${SDIR}/logo
  unset IFS
}

usage() {
  local usage
  IFS= read -d '' -r usage <<-EOF
Usage: $PROG [options] [...]

Description...

Options
  -h, --help     Print this message and exit
	EOF
  logo
  echo "$usage"
  unset IFS
}

color_codes() {
  local cmode="${COLORMODE:-off}"
  local cformat="${COLORFORMAT:-hex}"
  local fg_var=$(fg "$var")
  local fg_text=$(fg "text")
  local fmtd=$(chcmd pastel -m "$cmode" format "$cformat" "${!var}")
  printf '%s%s%s%s%s%s%s\n' "${fg_var}" "${block}" "${rst}" "${sep}" "${var}" "${sep}" "${fmtd}"
}

print_colors() {
  local flavor="$FLAVOR"

  for var in rosewater flamingo pink mauve red maroon peach yellow green teal sky sapphire blue lavender text subtext1 subtext0 overlay2 overlay1 overlay0 surface2 surface1 surface0 base mantle crust; do
    # start
    color_codes
  done | box -hp 1 -bc "${bc}" -t "${flavor}" -tc "${tc}" -s "${sep}"

}

list_colors() {
  local tc=$(fg mauve)
  local bc=$(fg surface0)
  local fg_text=$(fg "text")
  for col in rosewater flamingo pink mauve red maroon peach yellow green teal sky sapphire blue lavender text subtext1 subtext0 overlay2 overlay1 overlay0 surface2 surface1 surface0 base mantle crust; do
    printf '%s%s%s\n' "${fg_text}${col}${rst}"
  done | box -hp 1 -bc "${bc}" -t "colors:" -tc "${tc}" -s "${sep}"
}

list_flavors() {
  local current=${FLAVOR}
  local tc=$(fg mauve)
  local bc=$(fg surface0)
  for flav in mocha macchiato frappe latte; do
    if [[ "$flav" == "$current" ]]; then
      flavcol="$(fg pink)"
    else
      flavcol="$(fg text)"
    fi
    if [[ "$flav" == "$default_flavor" ]]; then
      printf "%s%s\n" "${flavcol}${flav}${rst}" "$(fg overlay2)(default)${rst}"
    else
      printf "%s\n" "${flavcol}${flav}${rst}"
    fi
  done | box -hp 1 -bc "${bc}" -t "flavors:" -tc "${tc}" -s "${sep}"
}

list_modes() {
  IFS= read -r colormodes <<-EOF
auto | off | 24bit | 8bit
	EOF
  echo "$colormodes" | box -hp 1 -bc "${bc}" -t "modes:" -tc "${tc}" -s "${sep}"
}

list_formats() {
  IFS= read -d '' -r colorformats <<-EOF
name hex cmyk luminance brightness
rgb[-float|-r|-g|-b]
hsl[-hue|-saturation|-lightness]
hsv[-hue|-saturation|-value]
lch[-lightness|-chroma|-hue]
oklch[-lightness|-chroma|-hue]
lab[-a|-b]
oklab[-l|-e|-b]
ansi-8bit[-value|-escapecode]
ansi-24bit[-value|-escapecode]
	EOF
  echo "$colorformats" | box -hp 1 -bc "${bc}" -t "formats:" -tc "${tc}" -s "${sep}"
}

print_all() {
  for flav in mocha macchiato frappe latte; do
    FLAVOR="$flav"
    case "$FLAVOR" in
    mocha) mocha ;;
    macchiato) macchiato ;;
    latte) latte ;;
    frappe) frappe ;;
    esac
    print_colors
  done
}

main() {
  local cmode
  local cformat
  COLOR=""
  # COLORMODE="auto"

  if [[ ! -z "$FLAVOR" ]]; then
    FLAVOR="$default_flavor"
  fi

  if [[ $# == 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    -a | --all)
      print_all
      exit 0
      ;;
    -f | --flavor)
      if [[ -n "$2" ]]; then
        FLAVOR="$2"
        shift 2
      else
        list_flavors
        exit 0
      fi
      ;;
    mocha | macchiato | frappe | latte)
      FLAVOR="$1"
      shift
      ;;
    -c | --color)
      if [[ -n "$2" ]]; then
        COLOR="$2"
        shift 2
      else
        list_colors
        exit 0
      fi
      ;;
    rosewater | flamingo | pink | mauve | red | maroon | peach | yellow | green | teal | sky | sapphire | blue | lavender | text | subtext1 | subtext0 | overlay2 | overlay1 | overlay0 | surface2 | surface1 | surface0 | base | mantle | crust)
      COLOR="$1"
      shift
      ;;
    --format)
      if [[ -n "$2" ]]; then
        COLORFORMAT="$2"
        shift 2
      else
        list_formats
        exit 0
      fi
      ;;
    rgb | rgb-float | rgb-r | rgb-g | rgb-b | hex | hsl | hsl-hue | hsl-saturation | hsl-lightness | hsv | hsv-hue | hsv-saturation | hsv-value | lch | lch-lightness | lch-chroma | lch-hue | oklch | oklch-lightness | oklch-chroma | oklch-hue | lab | lab-a | lab-b | oklab | oklab-l | oklab-a | oklab-b | luminance | brightness | ansi-8bit | ansi-24bit | ansi-8bit-value | ansi-8bit-escapecode | ansi-24bit-escapecode | cmyk | name)
      COLORFORMAT="$1"
      shift
      ;;
    -m | --mode)
      if [[ -n "$2" ]]; then
        COLORMODE="$2"
        shift 2
      else
        list_modes
        exit 0
      fi
      ;;
    auto | off | 24bit | 8bit)
      COLORMODE="$1"
      shift
      ;;
    -r | --raw)
      COLORMODE="off"
      shift
      ;;
    *)
      err "Unknown option: $1"
      exit 1
      ;;
    esac
  done

  case "$FLAVOR" in
  mocha) mocha ;;
  macchiato) macchiato ;;
  latte) latte ;;
  frappe) frappe ;;
  *)
    err "'$FLAVOR' is not a flavor."
    list_flavors
    exit 1
    ;;
  esac

  if [[ -n "$COLOR" ]]; then
    if [[ -n "${!COLOR}" ]]; then
      if [[ -n "$COLORFORMAT" ]]; then
        cmode="${COLOPMODE:-auto}"
        cformat="${COLORFORMAT:-hex}"
        chcmd pastel -m "$cmode" format "$cformat" "${!COLOR}"
      else
        echo "${!COLOR}"
      fi
    else
      echo
      err "Color '$COLOR' not found in flavor '$FLAVOR'."
      echo
      list_colors
      echo
      exit 1
    fi
  else
    print_colors
  fi
}

main "$@"
