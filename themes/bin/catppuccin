  lavender='#7287fd'
  text='#4c4f69'
  subtext1='#5c5f77'
  subtext0='#6c6f85'
  overlay2='#7c7f93'
  overlay1='#8c8fa1'
  overlay0='#9ca0b0'
  surface2='#acb0be'
  surface1='#bcc0cc'
  surface0='#ccd0da'
  crust='#dce0e8'
  mantle='#e6e9ef'
  base='#eff1f5'
}

declare ESC=$'\x1b'
default_flavor="mocha"
default_format="hex"
declare -r prog="${0##*/}"
declare -r sdir="${0%/*}"
declare sep='|'
declare aticon="󰄛"
declare block='󰄮'
declare logo="${sdir}/logo"
declare box=1
declare raw=0
declare array=0

err() { printf "${RED}%s%s%s${RST}\n" "[ERROR]" "$caticon" "$*" >&2; }
die() {
  err "$*"
  exit 1
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

cmd_exists() {
  command -v "$1" &>/dev/null
}

has -v pastel || die

chcmd() {
  "$@" &>/dev/null && "$@"
}

hex2rgb() {
  hex="$1"
  hex=${hex#\#}
  printf "%d %d %d\n" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

rgb2hex() {
  local ired="$1"
  local igreen="$2"
  local iblue="$3"
  printf "#%02x%02x%02x\n" "$ired" "$igreen" "$iblue"
}

escfg() {
  hex="$1"
  hex=${hex#\#}
  printf "${ESC}[38;2;%d;%d;%dm\n" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

escbg() {
  hex="$1"
  hex=${hex#\#}
  printf "${ESC}[48;2;%d;%d;%dm\n" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

tc="$GREEN"
bc="$BLACK"

logo() {
  local IFS=
  while read -r logo; do
    echo "$logo"
  done <"$logo"
  unset IFS
}

usage() {
  local IFS=
  local usage
  read -d '' -r usage <<-EOF
Usage: ${prog} [options] [...]

Description...

Options
  -h, --help     Print this message and exit
	EOF
  logo
  echo "$usage"
  unset IFS
}

color_codes() {
  local flavor="$FLAVOR"
  local var="$1"
  local format="$COLORFORMAT"
  local varcol="$(escfg "${!var}")"
  local fmtd=$(chcmd pastel -m off format "$COLORFORMAT" "${!var}")
  if ((raw)); then
    if ((array)); then
      case "$format" in
      ansi-24bit) format="ansi" ;;
      rgb-r) format="r" ;;
      rgb-g) format="g" ;;
      rgb-b) format="b" ;;
      *) format="$format" ;;
      esac
      printf '%s[%s]="%s";' "$var" "$format" "$fmtd"
    else
      printf "%s='%s'\n" "${var}" "${fmtd}"
    fi
  else
    printf '%s|%s|%s\n' "${varcol}${block}${rst}" "${var}" "${fmtd}"
  fi
}

print_colors() {
  local IFS=
  local flavor="$FLAVOR"
  local format="$COLORFORMAT"
  local codes=()
  local var

  for var in "${palette[@]}"; do

    codes+=($(color_codes "$var"))

  done
  if ((box)); then
    printf '%s\n' "${codes[@]}" | box -hp 1 -bc "${bc}" -t "$flavor[$format]" -tc "${tc}" -s '|'
  else
    if ((raw)); then
      if ((array)); then
        for code in "${codes[@]}"; do
          echo "$code"
        done
      else
        for code in "${codes[@]}"; do
          echo "$code"
        done
      fi
    fi
  fi
}

list_colors() {
  local tc="$GREEN"
  local bc="$BLACK"
  local vcol="$WHITE"
  if ((raw)); then
    echo "${palette[@]}"
  else
    for col in "${palette[@]}"; do
      printf '%s%s%s\n' "${vcol}${col}${rst}"
    done | box -hp 1 -bc "$bc" -t "colors:" -tc "${tc}" -s "${sep}"
  fi
}

list_flavors() {
  local current=${FLAVOR}
  local tc=${GREEN}
  local bc=${BLACK}

  if ((raw)); then
    echo "${flavors[@]}"
  else
    for flav in "${flavors[@]}"; do
      if [[ "$flav" == "$current" ]]; then
        flavcol="${MAGENTA}"
      else
        flavcol="${WHITE}"
      fi
      if [[ "$flav" == "$default_flavor" ]]; then
        printf "%s%s\n" "${flavcol}${flav}${rst}" "${BRIGHTBLACK}(default)${rst}"
      else
        printf "%s\n" "${flavcol}${flav}${rst}"
      fi
    done | box -hp 1 -bc "${bc}" -t "flavors:" -tc "${tc}" -s "${sep}"
  fi
}

list_formats() {
  local IFS=
  local colorsformats
  read -d '' -ra colorformats <<-EOF
name hex cmyk luminance brightness

rgb|-float|-r|-g|-b

hsl|-hue|-saturation|-lightness

hsv|-hue|-saturation|-value

lch|-lightness|-chroma|-hue

oklch|-lightness|-chroma|-hue

lab|-a|-b

oklab|-l|-e|-b

ansi-8bit|-value|-escapecode

ansi-24bit|-value|-escapecode
	EOF
  echo "${colorformats[@]}" | box -hp 1 -bc "${bc}" -t "formats:" -tc "${tc}" -s ''
  unset IFS
}

print_all() {
  for flav in "${flavors[@]}"; do
    FLAVOR="$flav"
    case "$FLAVOR" in
    mocha) mocha ;;
    macchiato) macchiato ;;
    latte) latte ;;
    frappe) frappe ;;
    esac
    print_colors
  done
}

init() {
  local formats=("hex" "ansi-24bit" "rgb" "rgb-r" "rgb-g" "rgb-b")
  raw=1
  array=1
  box=0
  for color in "${palette[@]}"; do
    echo "declare -xgA $color;"
  done

  case "$FLAVOR" in
  mocha) mocha ;;
  macchiato) macchiato ;;
  latte) latte ;;
  frappe) frappe ;;
  *)
    err "'$FLAVOR' is not a flavor."
    list_flavors
    exit 1
    ;;
  esac

  for format in "${formats[@]}"; do
    COLORFORMAT="$format"
    print_colors
  done
}

main() {
  raw=0
  array=0
  box=1
  local box=1
  local raw=0
  local array=0
  COLOR=""
  COLORFORMAT=""
  COLORMODE=""

  if [[ $# == 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    init | --init)
      init
      exit
      ;;
    -a | --array)
      raw=1
      array=1
      box=0
      shift
      ;;
    -r | --raw)
      raw=1
      box=0
      shift
      ;;
    -h | --help)
      usage
      exit
      ;;
    --all)
      print_all
      exit
      ;;
    -f | --flavor)
      if [[ -n "$2" ]]; then
        FLAVOR="$2"
        shift 2
      else
        list_flavors
        exit
      fi
      ;;
    mocha | macchiato | frappe | latte)
      FLAVOR="$1"
      shift
      ;;
    -c | --color)
      if [[ -n "$2" ]]; then
        COLOR="$2"
        shift 2
      else
        list_colors
        exit
      fi
      ;;
    rosewater | flamingo | pink | mauve | red | maroon | peach | yellow | green | teal | sky | sapphire | blue | lavender | text | subtext1 | subtext0 | overlay2 | overlay1 | overlay0 | surface2 | surface1 | surface0 | base | mantle | crust)
      COLOR="$1"
      shift
      ;;
    -F | --format)
      if [[ -n "$2" ]]; then
        COLORFORMAT="$2"
        shift 2
      else
        list_formats
        exit
      fi
      ;;
    esc | -e)
      COLORFORMAT="ansi-24bit-escapecode"
      shift
      ;;
    rgb | rgb-float | rgb-r | rgb-g | rgb-b | hex | hsl | hsl-hue | hsl-saturation | hsl-lightness | hsv | hsv-hue | hsv-saturation | hsv-value | lch | lch-lightness | lch-chroma | lch-hue | oklch | oklch-lightness | oklch-chroma | oklch-hue | lab | lab-a | lab-b | oklab | oklab-l | oklab-a | oklab-b | luminance | brightness | ansi-8bit | ansi-24bit | ansi-8bit-value | ansi-8bit-escapecode | ansi-24bit-escapecode | cmyk | name)
      COLORFORMAT="$1"
      shift
      ;;
    *)
      err "Unknown option: $1"
      exit 1
      ;;
    esac
  done

  if [[ -z "$COLORFORMAT" ]]; then
    COLORFORMAT="$default_format"
  fi

  case "$FLAVOR" in
  mocha) mocha ;;
  macchiato) macchiato ;;
  latte) latte ;;
  frappe) frappe ;;
  *)
    err "'$FLAVOR' is not a flavor."
    list_flavors
    exit 1
    ;;
  esac

  if [[ -n "$COLOR" ]]; then
    if [[ -n "${!COLOR}" ]]; then
      if [[ -n "$COLORFORMAT" ]]; then
        chcmd pastel -m off format "$COLORFORMAT" "${!COLOR}"
      else
        echo "${!COLOR}"
      fi
    else
      echo
      err "Color '$COLOR' not found in flavor '$FLAVOR'."
      echo
      list_colors
      echo
      exit 1
    fi
  else
    print_colors
  fi
}

main "$@"
