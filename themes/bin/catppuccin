  rosewater='#f2d5cf'
  flamingo='#eebebe'
  pink='#f4b8e4'
  mauve='#ca9ee6'
  red='#e78284'
  maroon='#ea999c'
  peach='#ef9f76'
  yellow='#e5c890'
  green='#a6d189'
  teal='#81c8be'
  sky='#99d1db'
  sapphire='#85c1dc'
  blue='#8caaee'
  lavender='#babbf1'
  text='#c6d0f5'
  subtext1='#b5bfe2'
  subtext0='#a5adce'
  overlay2='#949cbb'
  overlay1='#838ba7'
  overlay0='#737994'
  surface2='#626880'
  surface1='#51576d'
  surface0='#414559'
  base='#303446'
  mantle='#292c3c'
  crust='#232634'
}

esc=$'\033'
rst="${esc}[0m"
bold="${esc}[1m"
dim="${esc}[2m"
italic="${esc}[3m"
underline="${esc}[4m"
rev="${esc}[7m"
black="${esc}[30m"
red="${esc}[31m"
green="${esc}[32m"
yellow="${esc}[33m"
blue="${esc}[34m"
magenta="${esc}[35m"
cyan="${esc}[36m"
white="${esc}[37m"

default_flavor="mocha"
default_format="hex"
declare -r prog="${0##*/}"
declare -r sdir="${0%/*}"
declare ep='|'
declare aticon="󰄛"
declare block='󰄮'
declare logo="${sdir}/logo"
declare box=1
declare raw=0
declare array=0

err() { printf "${red}%s %s %s${rst}\n" "[ERROR]" "$caticon" "$*" >&2; }
die() {
  err "$*"
  exit 1
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

cmd_exists() {
  command -v "$1" &>/dev/null
}

has -v pastel || die

chcmd() {
  "$@" &>/dev/null && "$@"
}

hex2rgb() {
  hex="$1"
  hex=${hex#\#}
  printf "%d %d %d\n" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

rgb2hex() {
  local ired="$1"
  local igreen="$2"
  local iblue="$3"
  printf "#%02x%02x%02x\n" "$ired" "$igreen" "$iblue"
}

fg() {
  COLOR="$1"
  local r=$(chcmd pastel format rgb-r ${!COLOR})
  local g=$(chcmd pastel format rgb-g ${!COLOR})
  local b=$(chcmd pastel format rgb-b ${!COLOR})
  local fg="${esc}[38;2;${r};${g};${b}m"

  printf "%s" "$fg"
}

bg() {
  COLOR="$1"
  local r=$(chcmd pastel -m off format rgb-r ${!COLOR})
  local g=$(chcmd pastel -m off format rgb-g ${!COLOR})
  local b=$(chcmd pastel -m off format rgb-b ${!COLOR})
  local bg="${esc}[48;2;${r};${g};${b}m"

  printf "%s" "$bg"
}

tc=$(fg mauve)
bc=$(fg surface0)

logo() {
  local IFS=
  while read -r logo; do
    echo "$logo"
  done <"$logo"
  unset IFS
}

usage() {
  local IFS=
  local usage
  read -d '' -r usage <<-EOF
Usage: ${prog} [options] [...]

Description...

Options
  -h, --help     Print this message and exit
	EOF
  logo
  echo "$usage"
  unset IFS
}

color_codes() {
  local var="$1"
  local format="$COLORFORMAT"
  local fg_var=$(fg "$var")
  local fg_text=$(fg "text")
  local fmtd=$(chcmd pastel -m off format "$COLORFORMAT" "${!var}")
  if ((raw)); then
    if ((array)); then
      printf '%s%s%s[%s]="%s"\n' "$flavor" "_" "$format" "$var" "${fmtd}"

    else
      printf "%s='%s'\n" "${var}" "${fmtd}"
    fi
  else
    printf '%s|%s|%s\n' "${fg_var}${block}${rst}" "${var}" "${fmtd}"
  fi
}

print_colors() {
  local IFS=
  local flavor="$FLAVOR"
  local format="$COLORFORMAT"
  local codes=()
  local var

  for var in rosewater flamingo pink mauve red maroon peach yellow green teal sky sapphire blue lavender text subtext1 subtext0 overlay2 overlay1 overlay0 surface2 surface1 surface0 base mantle crust; do

    codes+=($(color_codes "$var"))

  done
  if ((box)); then
    printf '%s\n' "${codes[@]}" | box -hp 1 -bc "${bc}" -t "$flavor[$format]" -tc "${tc}" -s '|'
  else
    if ((array)); then
      echo "declare -A "${flavor}"_"${format}";"
      for code in "${codes[@]}"; do
        echo "$code;"
      done
    else
      echo "$flavor["$format"]"
      printf '%s\n' "${codes[@]}"
    fi
  fi
}

list_colors() {
  local tc=$(fg mauve)
  local bc=$(fg surface0)
  local fg_text=$(fg "text")
  for col in rosewater flamingo pink mauve red maroon peach yellow green teal sky sapphire blue lavender text subtext1 subtext0 overlay2 overlay1 overlay0 surface2 surface1 surface0 base mantle crust; do
    printf '%s%s%s\n' "${fg_text}${col}${rst}"
  done | box -hp 1 -bc "${bc}" -t "colors:" -tc "${tc}" -s "${sep}"
}

list_flavors() {
  local current=${FLAVOR}
  local tc=$(fg mauve)
  local bc=$(fg surface0)
  for flav in mocha macchiato frappe latte; do
    if [[ "$flav" == "$current" ]]; then
      flavcol="$(fg pink)"
    else
      flavcol="$(fg text)"
    fi
    if [[ "$flav" == "$default_flavor" ]]; then
      printf "%s%s\n" "${flavcol}${flav}${rst}" "$(fg overlay2)(default)${rst}"
    else
      printf "%s\n" "${flavcol}${flav}${rst}"
    fi
  done | box -hp 1 -bc "${bc}" -t "flavors:" -tc "${tc}" -s "${sep}"
}

list_formats() {
  local IFS=
  local colorsformats
  read -d '' -ra colorformats <<-EOF
name hex cmyk luminance brightness

rgb|-float|-r|-g|-b

hsl|-hue|-saturation|-lightness

hsv|-hue|-saturation|-value

lch|-lightness|-chroma|-hue

oklch|-lightness|-chroma|-hue

lab|-a|-b

oklab|-l|-e|-b

ansi-8bit|-value|-escapecode

ansi-24bit|-value|-escapecode
	EOF
  echo "${colorformats[@]}" | box -hp 1 -bc "${bc}" -t "formats:" -tc "${tc}" -s ''
  unset IFS
}

print_all() {
  for flav in mocha macchiato frappe latte; do
    FLAVOR="$flav"
    case "$FLAVOR" in
    mocha) mocha ;;
    macchiato) macchiato ;;
    latte) latte ;;
    frappe) frappe ;;
    esac
    print_colors
  done
}

main() {
  local box=1
  local raw=0
  local array=0
  COLOR=""
  COLORFORMAT=""
  COLORMODE=""

  if [[ ! -z "$FLAVOR" ]]; then
    FLAVOR="$default_flavor"
  fi

  if [[ -z "$COLORFORMAT" ]]; then
    COLORFORMAT="$default_format"
  fi

  if [[ $# == 0 ]]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -a | --array)
      raw=1
      array=1
      box=0
      shift
      ;;
    -r | --raw)
      raw=1
      box=0
      shift
      ;;
    -h | --help)
      usage
      exit
      ;;
    --all)
      print_all
      exit
      ;;
    -f | --flavor)
      if [[ -n "$2" ]]; then
        FLAVOR="$2"
        shift 2
      else
        list_flavors
        exit
      fi
      ;;
    mocha | macchiato | frappe | latte)
      FLAVOR="$1"
      shift
      ;;
    -c | --color)
      if [[ -n "$2" ]]; then
        COLOR="$2"
        shift 2
      else
        list_colors
        exit
      fi
      ;;
    rosewater | flamingo | pink | mauve | red | maroon | peach | yellow | green | teal | sky | sapphire | blue | lavender | text | subtext1 | subtext0 | overlay2 | overlay1 | overlay0 | surface2 | surface1 | surface0 | base | mantle | crust)
      COLOR="$1"
      shift
      ;;
    --format)
      if [[ -n "$2" ]]; then
        COLORFORMAT="$2"
        shift 2
      else
        list_formats
        exit
      fi
      ;;
    esc | -e)
      COLORFORMAT="ansi-24bit-escapecode"
      shift
      ;;
    rgb | rgb-float | rgb-r | rgb-g | rgb-b | hex | hsl | hsl-hue | hsl-saturation | hsl-lightness | hsv | hsv-hue | hsv-saturation | hsv-value | lch | lch-lightness | lch-chroma | lch-hue | oklch | oklch-lightness | oklch-chroma | oklch-hue | lab | lab-a | lab-b | oklab | oklab-l | oklab-a | oklab-b | luminance | brightness | ansi-8bit | ansi-24bit | ansi-8bit-value | ansi-8bit-escapecode | ansi-24bit-escapecode | cmyk | name)
      COLORFORMAT="$1"
      shift
      ;;
    *)
      err "Unknown option: $1"
      exit 1
      ;;
    esac
  done

  case "$FLAVOR" in
  mocha) mocha ;;
  macchiato) macchiato ;;
  latte) latte ;;
  frappe) frappe ;;
  *)
    err "'$FLAVOR' is not a flavor."
    list_flavors
    exit 1
    ;;
  esac

  if [[ -n "$COLOR" ]]; then
    if [[ -n "${!COLOR}" ]]; then
      if [[ -n "$COLORFORMAT" ]]; then
        chcmd pastel -m off format "$COLORFORMAT" "${!COLOR}"
      else
        echo "${!COLOR}"
      fi
    else
      echo
      err "Color '$COLOR' not found in flavor '$FLAVOR'."
      echo
      list_colors
      echo
      exit 1
    fi
  else
    print_colors
  fi
}

main "$@"
