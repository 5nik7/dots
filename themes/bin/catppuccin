#!/usr/bin/env bash

if [ -z $FLAVOR ]; then
  FLAVOR='mocha'
fi

flavors=(mocha macchiato frappe latte)

palette=(rosewater flamingo pink mauve red maroon peach yellow green teal sky sapphire blue lavender text subtext1 subtext0 overlay2 overlay1 overlay0 surface2 surface0 base mantle crust)

