  rosewater
  flamingo
  pink m
  auve
  red
  maroon
  peach
  yellow
  green
  teal
  sky
  sapphire
  blue
  lavender
  text
  subtext1
  subtext0
  overlay2
  overlay1
  overlay0
  surface2
  surface0
  base
  mantle
  crust
)

