#!/usr/bin/env bash

set -euo pipefail

usage() {
	cat <<'USAGE_EOF'
linked - inspect the symlinked parent component inside a path

Usage:
  linked [option] [PATH] [-r|--raw]
  linked [PATH] -f|--format FORMAT [-r|--raw]
  linked [PATH] -j|--json [-r|--raw]
  linked [PATH] -A|--arrays [auto|bash|zsh] [-r|--raw]
  linked --completion bash|zsh

Default:
  Inspect PATH if provided; otherwise inspect $PWD.
  Print the full symlink path found inside the inspected path, formatted with ~ for $HOME.

Path input:
  PATH                     Existing file or directory path to inspect.
                           Relative paths are resolved from the current $PWD
                           while preserving logical symlink components.

Options:
      --full               Print full symlink path (default)
  -d, --dirname            Print dirname of the symlink path
  -b, --basename           Print basename of the symlink path
  -p, --prefix             Print path below the symlink within the inspected path

  -s, --source             Print full symlink source/target path
  -D, --source-dirname     Print dirname of the symlink source/target path
  -B, --source-basename    Print basename of the symlink source/target path

  -C, --shared-prefix      Print shared/common prefix directory between
                           the symlink path and source path

  -e, --link-branch-dir    Print symlink-side directory path after the shared
                           prefix and before the symlink basename
  -E, --source-branch-dir  Print source-side directory path after the shared
                           prefix and before the source basename

  -m, --shared-basename    Print basename only if symlink basename and source
                           basename match; otherwise print nothing

  -f, --format FORMAT      Print custom formatted output
  -j, --json               Print all collected linked data as JSON
  -A, --arrays [SHELL]     Print eval-safe associative arrays
      --array [SHELL]      Alias for --arrays

  -r, --raw                Do not replace $HOME with ~ for normal/string output
  -h, --help               Show this help

      --completion SHELL   Print completion script for bash or zsh

Array shells:
  auto                     Detect from $LINKED_ARRAY_SHELL or $SHELL
  bash                     Emit Bash declare -gA syntax
  zsh                      Emit zsh typeset -gA syntax

Format placeholders:
  %l   full symlink path
  %d   symlink dirname
  %b   symlink basename
  %p   prefix below the symlink in the inspected path

  %s   full source/target path
  %D   source dirname
  %B   source basename
  %P   full source path plus prefix

  %c   shared/common prefix directory between symlink path and source path
  %e   symlink-side branch directory after shared prefix, before symlink basename
  %E   source-side branch directory after shared prefix, before source basename
  %m   shared basename if symlink/source basenames match; otherwise empty

  %%   literal percent sign

Examples:
  linked
  linked ~/.config/glow/styles
  linked ~/.config/glow/styles --source
  linked ~/.config/glow/styles --shared-prefix
  linked ~/.config/glow/styles --link-branch-dir
  linked ~/.config/glow/styles --source-branch-dir
  linked ~/.config/glow/styles --shared-basename

  linked ~/.config/glow/styles -f '%d/%b/%p -> %D/%B/%p'
  linked ~/.config/glow/styles -f 'shared: %c'
  linked ~/.config/glow/styles -f 'link branch: %e'
  linked ~/.config/glow/styles -f 'source branch: %E'
  linked ~/.config/glow/styles -f 'shared basename: %m'
  linked ~/.config/glow/styles -f '%c/{%e,%E}/%m'
  linked ~/.config/glow/styles -f '%l -> %P'

JSON:
  linked ~/.config/glow/styles --json

Arrays:
  # zsh users:
  eval "$(linked ~/.config/glow/styles --arrays zsh)"

  # bash users:
  eval "$(linked ~/.config/glow/styles --arrays bash)"

  # no path still uses $PWD:
  eval "$(linked --arrays)"

  echo "${linked[target_path]}"
  echo "${linked[symlink_path]}"
  echo "${linked_raw[source_path]}"
  echo "${linked[link_branch_dir]}"
  echo "${linked[source_branch_dir]}"
  echo "${linked[bases_match]}"
  echo "${linked[shared_basename]}"
  echo "${linked_target_parts[1]}"
  echo "${linked_source_parts[3]}"

Completion:
  linked --completion bash > ~/.local/share/bash-completion/completions/linked

  linked --completion zsh > ~/.zfunc/_linked

Notes:
  - linked searches the inspected path component-by-component and uses the deepest symlink found.
  - If no symlink component exists in the inspected path, linked exits non-zero.
  - If PATH is omitted, linked behaves exactly like before and inspects $PWD.
  - PATH must exist. Use -- before PATH if the path starts with a dash.
  - %P is shorthand for the source path with the current prefix appended.
  - %c compares the symlink path and source path by path components, not raw string characters.
  - %e and %E are relative branch directories from %c to the parent dirs of %b and %B.
  - %m is non-empty only when %b and %B are identical.
  - --json includes raw paths, display paths, path parts, branch dirs, basename match info, and metadata.
  - --arrays outputs shell code intended for eval. Use --arrays zsh when evaling in zsh.
USAGE_EOF
}

completion_bash() {
	cat <<'BASH_COMPLETION_EOF'
# bash completion for linked

_linked() {
	local cur prev
	COMPREPLY=()

	cur="${COMP_WORDS[COMP_CWORD]}"
	prev="${COMP_WORDS[COMP_CWORD-1]}"

	case "$prev" in
		--completion)
			COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
			return 0
			;;
		-f|--format)
			return 0
			;;
		-A|--arrays|--array)
			COMPREPLY=( $(compgen -W "auto bash zsh" -- "$cur") )
			return 0
			;;
	esac

	case "$cur" in
		--completion=*)
			COMPREPLY=( $(compgen -W "bash zsh" -- "${cur#--completion=}") )
			COMPREPLY=( "${COMPREPLY[@]/#/--completion=}" )
			return 0
			;;
		--arrays=*|--array=*)
			local prefix value
			prefix=${cur%%=*}=
			value=${cur#*=}
			COMPREPLY=( $(compgen -W "auto bash zsh" -- "$value") )
			COMPREPLY=( "${COMPREPLY[@]/#/$prefix}" )
			return 0
			;;
		--format=*)
			return 0
			;;
	esac

	local opts="
		--full
		-d --dirname
		-b --basename
		-p --prefix
		-s --source
		-D --source-dirname
		-B --source-basename
		-C --shared-prefix
		-e --link-branch-dir
		-E --source-branch-dir
		-m --shared-basename
		-f --format
		-j --json
		-A --arrays --array
		-r --raw
		-h --help
		--completion
		--
	"

	if [[ $cur == -* ]]; then
		COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
	else
		COMPREPLY=( $(compgen -f -- "$cur") )
	fi

	return 0
}

complete -F _linked linked
BASH_COMPLETION_EOF
}

completion_zsh() {
	cat <<'ZSH_COMPLETION_EOF'
#compdef linked
# zsh completion for linked

_linked() {
	_arguments -s \
		'--full[print full symlink path]' \
		'(-d --dirname)'{-d,--dirname}'[print dirname of the symlink path]' \
		'(-b --basename)'{-b,--basename}'[print basename of the symlink path]' \
		'(-p --prefix)'{-p,--prefix}'[print path below the symlink within inspected path]' \
		'(-s --source)'{-s,--source}'[print full symlink source/target path]' \
		'(-D --source-dirname)'{-D,--source-dirname}'[print dirname of the source/target path]' \
		'(-B --source-basename)'{-B,--source-basename}'[print basename of the source/target path]' \
		'(-C --shared-prefix)'{-C,--shared-prefix}'[print shared prefix between symlink and source paths]' \
		'(-e --link-branch-dir)'{-e,--link-branch-dir}'[print symlink-side branch dir after shared prefix before basename]' \
		'(-E --source-branch-dir)'{-E,--source-branch-dir}'[print source-side branch dir after shared prefix before basename]' \
		'(-m --shared-basename)'{-m,--shared-basename}'[print basename only if symlink and source basenames match]' \
		'(-f --format)'{-f,--format}'[print custom formatted output]:format string:' \
		'(-j --json)'{-j,--json}'[print all collected linked data as JSON]' \
		'(-A --arrays --array)'{-A,--arrays,--array}'[print eval-safe associative arrays]::shell:(auto bash zsh)' \
		'(-r --raw)'{-r,--raw}'[do not replace HOME with ~]' \
		'(-h --help)'{-h,--help}'[show help]' \
		'--completion[print shell completion script]:shell:(bash zsh)' \
		'1:target path:_files'
}

_linked "$@"
ZSH_COMPLETION_EOF
}

print_completion() {
	local shell=$1

	case "$shell" in
		bash)
			completion_bash
			;;
		zsh)
			completion_zsh
			;;
		*)
			printf 'linked: unsupported completion shell: %s\n' "$shell" >&2
			printf 'linked: expected one of: bash, zsh\n' >&2
			exit 2
			;;
	esac
}

display_path() {
	local path=$1

	if [[ -n ${HOME:-} ]]; then
		if [[ $path == "$HOME" ]]; then
			printf '~'
		elif [[ $path == "$HOME"/* ]]; then
			printf '~/%s' "${path#"$HOME"/}"
		else
			printf '%s' "$path"
		fi
	else
		printf '%s' "$path"
	fi
}

format_path() {
	local path=$1

	if (( RAW )); then
		printf '%s' "$path"
	else
		display_path "$path"
	fi
}

print_path() {
	local path=$1
	format_path "$path"
	printf '\n'
}

join_dir_base() {
	local dir=$1
	local base=$2

	if [[ $dir == "/" ]]; then
		printf '/%s\n' "$base"
	else
		printf '%s/%s\n' "${dir%/}" "$base"
	fi
}

resolve_target_logical_path() {
	local input=$1
	local dir base logical_dir

	if [[ -d $input ]]; then
		logical_dir=$(cd -L -- "$input" 2>/dev/null && pwd -L) || return 1
		if [[ $logical_dir == "/" ]]; then
			printf '/\n'
		else
			printf '%s\n' "${logical_dir%/}"
		fi
	else
		dir=$(dirname -- "$input")
		base=$(basename -- "$input")
		logical_dir=$(cd -L -- "$dir" 2>/dev/null && pwd -L) || return 1
		join_dir_base "$logical_dir" "$base"
	fi
}

resolve_target_physical_path() {
	local input=$1
	local dir base physical_dir

	if [[ -d $input ]]; then
		physical_dir=$(cd -P -- "$input" 2>/dev/null && pwd -P) || return 1
		if [[ $physical_dir == "/" ]]; then
			printf '/\n'
		else
			printf '%s\n' "${physical_dir%/}"
		fi
	else
		dir=$(dirname -- "$input")
		base=$(basename -- "$input")
		physical_dir=$(cd -P -- "$dir" 2>/dev/null && pwd -P) || return 1
		join_dir_base "$physical_dir" "$base"
	fi
}

prepare_target_path() {
	local input=$1

	if [[ ! -e $input && ! -L $input ]]; then
		printf 'linked: path does not exist: %s\n' "$input" >&2
		exit 1
	fi

	TARGET_PATH=$(resolve_target_logical_path "$input") || {
		printf 'linked: unable to resolve path: %s\n' "$input" >&2
		exit 1
	}

	TARGET_PATH_PHYSICAL=$(resolve_target_physical_path "$input") || {
		printf 'linked: unable to resolve physical path: %s\n' "$input" >&2
		exit 1
	}
}

abspath() {
	local path=$1
	local base=${2:-$TARGET_PATH}

	if [[ $path == /* ]]; then
		printf '%s\n' "$path"
	else
		printf '%s\n' "$base/$path"
	fi
}

normalize_path() {
	local path=$1
	local dir base physical_dir

	dir=$(dirname -- "$path")
	base=$(basename -- "$path")

	if physical_dir=$(cd -P -- "$dir" 2>/dev/null && pwd -P); then
		printf '%s/%s\n' "$physical_dir" "$base"
	else
		printf '%s\n' "$path"
	fi
}

find_deepest_symlink_in_path() {
	local path="${1%/}"
	local cur=""
	local part
	local -a parts
	local i

	SYMLINK_PATH=""
	SYMLINK_INDEX=-1

	[[ -z $path ]] && path="/"

	IFS='/' read -r -a parts <<< "$path"

	if [[ $path == /* ]]; then
		cur="/"
	fi

	for i in "${!parts[@]}"; do
		part=${parts[i]}
		[[ -z $part ]] && continue

		if [[ $cur == "/" ]]; then
			cur="/$part"
		elif [[ -z $cur ]]; then
			cur="$part"
		else
			cur="$cur/$part"
		fi

		if [[ -L $cur ]]; then
			SYMLINK_PATH=$cur
			SYMLINK_INDEX=$i
		fi
	done

	[[ -n $SYMLINK_PATH ]]
}

build_prefix_from_index() {
	local idx=$1
	local path="${2%/}"
	local -a parts
	local out=()
	local i

	IFS='/' read -r -a parts <<< "$path"

	for i in "${!parts[@]}"; do
		[[ -z ${parts[i]} ]] && continue

		if (( i > idx )); then
			out+=("${parts[i]}")
		fi
	done

	if ((${#out[@]})); then
		local IFS=/
		printf '%s\n' "${out[*]}"
	else
		printf '\n'
	fi
}

join_path_and_prefix() {
	local base=$1
	local prefix=$2

	if [[ -z $prefix ]]; then
		printf '%s\n' "$base"
	else
		printf '%s/%s\n' "${base%/}" "$prefix"
	fi
}

common_prefix_path() {
	local a=${1%/}
	local b=${2%/}
	local a_abs=0
	local b_abs=0
	local a_trim b_trim
	local -a a_parts b_parts out
	local i max

	[[ -z $a ]] && a="/"
	[[ -z $b ]] && b="/"

	[[ $a == /* ]] && a_abs=1
	[[ $b == /* ]] && b_abs=1

	a_trim=${a#/}
	b_trim=${b#/}

	IFS='/' read -r -a a_parts <<< "$a_trim"
	IFS='/' read -r -a b_parts <<< "$b_trim"

	max=${#a_parts[@]}
	((${#b_parts[@]} < max)) && max=${#b_parts[@]}

	for ((i = 0; i < max; i++)); do
		[[ -z ${a_parts[i]} && -z ${b_parts[i]} ]] && continue
		[[ ${a_parts[i]} == "${b_parts[i]}" ]] || break
		out+=("${a_parts[i]}")
	done

	if (( a_abs && b_abs )); then
		if ((${#out[@]})); then
			local IFS=/
			printf '/%s\n' "${out[*]}"
		else
			printf '/\n'
		fi
	else
		if ((${#out[@]})); then
			local IFS=/
			printf '%s\n' "${out[*]}"
		else
			printf '\n'
		fi
	fi
}

relative_after_prefix() {
	local path=${1%/}
	local prefix=${2%/}

	if [[ -z $path ]]; then
		printf '\n'
		return
	fi

	if [[ -z $prefix ]]; then
		printf '%s\n' "$path"
		return
	fi

	if [[ $path == "$prefix" ]]; then
		printf '\n'
		return
	fi

	if [[ $prefix == "/" ]]; then
		printf '%s\n' "${path#/}"
		return
	fi

	if [[ $path == "$prefix"/* ]]; then
		printf '%s\n' "${path#"$prefix"/}"
	else
		printf '%s\n' "$path"
	fi
}

path_part_count() {
	local path=${1%/}
	local trim
	local -a parts
	local count=0
	local part

	if [[ -z $path ]]; then
		printf '0\n'
		return
	fi

	if [[ $path == "/" ]]; then
		printf '1\n'
		return
	fi

	if [[ $path == /* ]]; then
		count=1
		trim=${path#/}
	else
		trim=$path
	fi

	IFS='/' read -r -a parts <<< "$trim"

	for part in "${parts[@]}"; do
		if [[ -n $part ]]; then
			count=$((count + 1))
		fi
	done

	printf '%s\n' "$count"
}

json_escape() {
	local s=$1

	s=${s//\\/\\\\}
	s=${s//\"/\\\"}
	s=${s//$'\t'/\\t}
	s=${s//$'\r'/\\r}
	s=${s//$'\n'/\\n}

	printf '%s' "$s"
}

json_string() {
	printf '"'
	json_escape "$1"
	printf '"'
}

json_bool() {
	case ${1:-0} in
		1|true|TRUE|yes|YES)
			printf 'true'
			;;
		*)
			printf 'false'
			;;
	esac
}

json_path_parts() {
	local path=${1%/}
	local trim
	local -a parts
	local part
	local first=1

	printf '['

	if [[ -z $path ]]; then
		printf ']'
		return
	fi

	if [[ $path == "/" ]]; then
		json_string "/"
		printf ']'
		return
	fi

	if [[ $path == /* ]]; then
		json_string "/"
		first=0
		trim=${path#/}
	else
		trim=$path
	fi

	IFS='/' read -r -a parts <<< "$trim"

	for part in "${parts[@]}"; do
		[[ -n $part ]] || continue

		if (( first )); then
			first=0
		else
			printf ','
		fi

		json_string "$part"
	done

	printf ']'
}

print_json() {
	local current_pwd_physical

	current_pwd_physical=$(pwd -P)

	printf '{\n'

	printf '  "tool": "linked",\n'

	printf '  "raw_output": '
	json_bool "$RAW"
	printf ',\n'

	printf '  "array_shell_default": '
	json_string "$(detect_array_shell)"
	printf ',\n'

	printf '  "input": {\n'
	printf '    "provided": '
	json_bool "$TARGET_ARG_PROVIDED"
	printf ',\n'
	printf '    "path": '
	json_string "$TARGET_INPUT"
	printf '\n'
	printf '  },\n'

	printf '  "current_pwd": {\n'
	printf '    "logical": '
	json_string "$PWD"
	printf ',\n'
	printf '    "physical": '
	json_string "$current_pwd_physical"
	printf ',\n'
	printf '    "display": '
	json_string "$(display_path "$PWD")"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$PWD"
	printf '\n'
	printf '  },\n'

	printf '  "target": {\n'
	printf '    "logical": '
	json_string "$TARGET_PATH"
	printf ',\n'
	printf '    "physical": '
	json_string "$TARGET_PATH_PHYSICAL"
	printf ',\n'
	printf '    "display": '
	json_string "$(display_path "$TARGET_PATH")"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$TARGET_PATH"
	printf '\n'
	printf '  },\n'

	printf '  "pwd": {\n'
	printf '    "logical": '
	json_string "$TARGET_PATH"
	printf ',\n'
	printf '    "physical": '
	json_string "$TARGET_PATH_PHYSICAL"
	printf ',\n'
	printf '    "display": '
	json_string "$(display_path "$TARGET_PATH")"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$TARGET_PATH"
	printf '\n'
	printf '  },\n'

	printf '  "symlink": {\n'
	printf '    "path": '
	json_string "$SYMLINK_PATH"
	printf ',\n'
	printf '    "display_path": '
	json_string "$(display_path "$SYMLINK_PATH")"
	printf ',\n'
	printf '    "dirname": '
	json_string "$SYMLINK_DIRNAME"
	printf ',\n'
	printf '    "display_dirname": '
	json_string "$(display_path "$SYMLINK_DIRNAME")"
	printf ',\n'
	printf '    "basename": '
	json_string "$SYMLINK_BASENAME"
	printf ',\n'
	printf '    "index": %s,\n' "$SYMLINK_INDEX"
	printf '    "readlink": '
	json_string "$LINK_TARGET"
	printf ',\n'
	printf '    "branch_dir": '
	json_string "$LINK_BRANCH_DIR"
	printf ',\n'
	printf '    "branch_parts": '
	json_path_parts "$LINK_BRANCH_DIR"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$SYMLINK_PATH"
	printf '\n'
	printf '  },\n'

	printf '  "source": {\n'
	printf '    "path": '
	json_string "$SOURCE_ABS"
	printf ',\n'
	printf '    "display_path": '
	json_string "$(display_path "$SOURCE_ABS")"
	printf ',\n'
	printf '    "dirname": '
	json_string "$SOURCE_DIRNAME"
	printf ',\n'
	printf '    "display_dirname": '
	json_string "$(display_path "$SOURCE_DIRNAME")"
	printf ',\n'
	printf '    "basename": '
	json_string "$SOURCE_BASENAME"
	printf ',\n'
	printf '    "branch_dir": '
	json_string "$SOURCE_BRANCH_DIR"
	printf ',\n'
	printf '    "branch_parts": '
	json_path_parts "$SOURCE_BRANCH_DIR"
	printf ',\n'
	printf '    "with_prefix": '
	json_string "$SOURCE_WITH_PREFIX"
	printf ',\n'
	printf '    "display_with_prefix": '
	json_string "$(display_path "$SOURCE_WITH_PREFIX")"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$SOURCE_ABS"
	printf ',\n'
	printf '    "with_prefix_parts": '
	json_path_parts "$SOURCE_WITH_PREFIX"
	printf '\n'
	printf '  },\n'

	printf '  "prefix": {\n'
	printf '    "path": '
	json_string "$PREFIX"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$PREFIX"
	printf ',\n'
	printf '    "part_count": %s\n' "$(path_part_count "$PREFIX")"
	printf '  },\n'

	printf '  "shared_prefix": {\n'
	printf '    "path": '
	json_string "$SHARED_PREFIX"
	printf ',\n'
	printf '    "display_path": '
	json_string "$(display_path "$SHARED_PREFIX")"
	printf ',\n'
	printf '    "parts": '
	json_path_parts "$SHARED_PREFIX"
	printf ',\n'
	printf '    "part_count": %s\n' "$(path_part_count "$SHARED_PREFIX")"
	printf '  },\n'

	printf '  "branch_dirs": {\n'
	printf '    "link": '
	json_string "$LINK_BRANCH_DIR"
	printf ',\n'
	printf '    "source": '
	json_string "$SOURCE_BRANCH_DIR"
	printf ',\n'
	printf '    "link_parts": '
	json_path_parts "$LINK_BRANCH_DIR"
	printf ',\n'
	printf '    "source_parts": '
	json_path_parts "$SOURCE_BRANCH_DIR"
	printf '\n'
	printf '  },\n'

	printf '  "basename": {\n'
	printf '    "link": '
	json_string "$SYMLINK_BASENAME"
	printf ',\n'
	printf '    "source": '
	json_string "$SOURCE_BASENAME"
	printf ',\n'
	printf '    "match": '
	json_bool "$BASES_MATCH"
	printf ',\n'
	printf '    "shared": '
	json_string "$SHARED_BASENAME"
	printf '\n'
	printf '  },\n'

	printf '  "placeholders": {\n'
	printf '    "%%l": '
	json_string "$(format_path "$SYMLINK_PATH")"
	printf ',\n'
	printf '    "%%d": '
	json_string "$(format_path "$SYMLINK_DIRNAME")"
	printf ',\n'
	printf '    "%%b": '
	json_string "$SYMLINK_BASENAME"
	printf ',\n'
	printf '    "%%p": '
	json_string "$PREFIX"
	printf ',\n'
	printf '    "%%s": '
	json_string "$(format_path "$SOURCE_ABS")"
	printf ',\n'
	printf '    "%%D": '
	json_string "$(format_path "$SOURCE_DIRNAME")"
	printf ',\n'
	printf '    "%%B": '
	json_string "$SOURCE_BASENAME"
	printf ',\n'
	printf '    "%%P": '
	json_string "$(format_path "$SOURCE_WITH_PREFIX")"
	printf ',\n'
	printf '    "%%c": '
	json_string "$(format_path "$SHARED_PREFIX")"
	printf ',\n'
	printf '    "%%e": '
	json_string "$LINK_BRANCH_DIR"
	printf ',\n'
	printf '    "%%E": '
	json_string "$SOURCE_BRANCH_DIR"
	printf ',\n'
	printf '    "%%m": '
	json_string "$SHARED_BASENAME"
	printf '\n'
	printf '  }\n'

	printf '}\n'
}

single_quote() {
	local s=$1

	s=${s//\'/\'\\\'\'}
	printf "'%s'" "$s"
}

bash_assoc_entry() {
	local key=$1
	local value=$2

	printf '  [%s]=%s\n' "$(single_quote "$key")" "$(single_quote "$value")"
}

zsh_assoc_entry() {
	local key=$1
	local value=$2

	printf '  %s %s\n' "$(single_quote "$key")" "$(single_quote "$value")"
}

emit_assoc_path_parts_bash() {
	local name=$1
	local path=${2%/}
	local trim
	local -a parts
	local part
	local idx=0

	printf 'declare -gA %s=(\n' "$name"

	if [[ -z $path ]]; then
		bash_assoc_entry "__length" 0
		printf ')\n'
		return
	fi

	if [[ $path == "/" ]]; then
		bash_assoc_entry 0 "/"
		bash_assoc_entry "__length" 1
		printf ')\n'
		return
	fi

	if [[ $path == /* ]]; then
		bash_assoc_entry "$idx" "/"
		idx=$((idx + 1))
		trim=${path#/}
	else
		trim=$path
	fi

	IFS='/' read -r -a parts <<< "$trim"

	for part in "${parts[@]}"; do
		[[ -n $part ]] || continue
		bash_assoc_entry "$idx" "$part"
		idx=$((idx + 1))
	done

	bash_assoc_entry "__length" "$idx"
	printf ')\n'
}

emit_assoc_path_parts_zsh() {
	local name=$1
	local path=${2%/}
	local trim
	local -a parts
	local part
	local idx=0

	printf 'typeset -gA %s\n' "$name"
	printf '%s=(\n' "$name"

	if [[ -z $path ]]; then
		zsh_assoc_entry "__length" 0
		printf ')\n'
		return
	fi

	if [[ $path == "/" ]]; then
		zsh_assoc_entry 0 "/"
		zsh_assoc_entry "__length" 1
		printf ')\n'
		return
	fi

	if [[ $path == /* ]]; then
		zsh_assoc_entry "$idx" "/"
		idx=$((idx + 1))
		trim=${path#/}
	else
		trim=$path
	fi

	IFS='/' read -r -a parts <<< "$trim"

	for part in "${parts[@]}"; do
		[[ -n $part ]] || continue
		zsh_assoc_entry "$idx" "$part"
		idx=$((idx + 1))
	done

	zsh_assoc_entry "__length" "$idx"
	printf ')\n'
}

emit_main_assoc_bash() {
	local name=$1
	shift
	local key value

	printf 'declare -gA %s=(\n' "$name"
	while (($#)); do
		key=$1
		value=$2
		bash_assoc_entry "$key" "$value"
		shift 2
	done
	printf ')\n'
}

emit_main_assoc_zsh() {
	local name=$1
	shift
	local key value

	printf 'typeset -gA %s\n' "$name"
	printf '%s=(\n' "$name"
	while (($#)); do
		key=$1
		value=$2
		zsh_assoc_entry "$key" "$value"
		shift 2
	done
	printf ')\n'
}

detect_array_shell() {
	local requested=${ARRAY_SHELL:-auto}
	local shell_name

	if [[ $requested != auto ]]; then
		printf '%s\n' "$requested"
		return
	fi

	if [[ -n ${LINKED_ARRAY_SHELL:-} ]]; then
		case ${LINKED_ARRAY_SHELL##*/} in
			zsh)
				printf 'zsh\n'
				return
				;;
			bash)
				printf 'bash\n'
				return
				;;
		esac
	fi

	shell_name=${SHELL##*/}
	case $shell_name in
		zsh)
			printf 'zsh\n'
			;;
		bash)
			printf 'bash\n'
			;;
		*)
			printf 'bash\n'
			;;
	esac
}

validate_array_shell() {
	case $1 in
		auto|bash|zsh)
			return 0
			;;
		*)
			printf 'linked: unsupported array shell: %s\n' "$1" >&2
			printf 'linked: expected one of: auto, bash, zsh\n' >&2
			exit 2
			;;
	esac
}

print_arrays_bash() {
	local current_pwd_physical

	current_pwd_physical=$(pwd -P)

	cat <<'BASH_ARRAYS_EOF'
# linked arrays for bash
# Usage:
#   eval "$(linked [PATH] --arrays bash)"
#
# Main arrays:
#   linked[...]      display/formatted values, affected by -r|--raw
#   linked_raw[...]  raw absolute/logical values
#
# Path part arrays:
#   linked_target_parts[0]
#   linked_pwd_parts[0]               # backward-compatible alias for target parts
#   linked_current_pwd_parts[0]
#   linked_symlink_parts[0]
#   linked_source_parts[0]
#   linked_source_with_prefix_parts[0]
#   linked_prefix_parts[0]
#   linked_shared_prefix_parts[0]
#   linked_link_branch_parts[0]
#   linked_source_branch_parts[0]
#
# Each path part array includes:
#   [0], [1], [2], ...
#   [__length]
BASH_ARRAYS_EOF

	emit_main_assoc_bash linked \
		"tool" "linked" \
		"array_shell" "bash" \
		"raw_output" "$RAW" \
		"input_provided" "$TARGET_ARG_PROVIDED" \
		"input_path" "$TARGET_INPUT" \
		"pwd" "$(format_path "$TARGET_PATH")" \
		"target_path" "$(format_path "$TARGET_PATH")" \
		"target_physical" "$(format_path "$TARGET_PATH_PHYSICAL")" \
		"current_pwd" "$(format_path "$PWD")" \
		"current_pwd_physical" "$(format_path "$current_pwd_physical")" \
		"symlink_path" "$(format_path "$SYMLINK_PATH")" \
		"symlink_dirname" "$(format_path "$SYMLINK_DIRNAME")" \
		"symlink_basename" "$SYMLINK_BASENAME" \
		"symlink_index" "$SYMLINK_INDEX" \
		"symlink_readlink" "$LINK_TARGET" \
		"link_branch_dir" "$LINK_BRANCH_DIR" \
		"source_path" "$(format_path "$SOURCE_ABS")" \
		"source_dirname" "$(format_path "$SOURCE_DIRNAME")" \
		"source_basename" "$SOURCE_BASENAME" \
		"source_branch_dir" "$SOURCE_BRANCH_DIR" \
		"source_with_prefix" "$(format_path "$SOURCE_WITH_PREFIX")" \
		"prefix" "$PREFIX" \
		"shared_prefix" "$(format_path "$SHARED_PREFIX")" \
		"bases_match" "$BASES_MATCH" \
		"shared_basename" "$SHARED_BASENAME" \
		"%l" "$(format_path "$SYMLINK_PATH")" \
		"%d" "$(format_path "$SYMLINK_DIRNAME")" \
		"%b" "$SYMLINK_BASENAME" \
		"%p" "$PREFIX" \
		"%s" "$(format_path "$SOURCE_ABS")" \
		"%D" "$(format_path "$SOURCE_DIRNAME")" \
		"%B" "$SOURCE_BASENAME" \
		"%P" "$(format_path "$SOURCE_WITH_PREFIX")" \
		"%c" "$(format_path "$SHARED_PREFIX")" \
		"%e" "$LINK_BRANCH_DIR" \
		"%E" "$SOURCE_BRANCH_DIR" \
		"%m" "$SHARED_BASENAME"

	printf '\n'

	emit_main_assoc_bash linked_raw \
		"tool" "linked" \
		"array_shell" "bash" \
		"input_provided" "$TARGET_ARG_PROVIDED" \
		"input_path" "$TARGET_INPUT" \
		"pwd" "$TARGET_PATH" \
		"target_path" "$TARGET_PATH" \
		"target_physical" "$TARGET_PATH_PHYSICAL" \
		"current_pwd" "$PWD" \
		"current_pwd_physical" "$current_pwd_physical" \
		"symlink_path" "$SYMLINK_PATH" \
		"symlink_dirname" "$SYMLINK_DIRNAME" \
		"symlink_basename" "$SYMLINK_BASENAME" \
		"symlink_index" "$SYMLINK_INDEX" \
		"symlink_readlink" "$LINK_TARGET" \
		"link_branch_dir" "$LINK_BRANCH_DIR" \
		"source_path" "$SOURCE_ABS" \
		"source_dirname" "$SOURCE_DIRNAME" \
		"source_basename" "$SOURCE_BASENAME" \
		"source_branch_dir" "$SOURCE_BRANCH_DIR" \
		"source_with_prefix" "$SOURCE_WITH_PREFIX" \
		"prefix" "$PREFIX" \
		"shared_prefix" "$SHARED_PREFIX" \
		"bases_match" "$BASES_MATCH" \
		"shared_basename" "$SHARED_BASENAME"

	printf '\n'
	emit_assoc_path_parts_bash "linked_target_parts" "$TARGET_PATH"
	printf '\n'
	emit_assoc_path_parts_bash "linked_pwd_parts" "$TARGET_PATH"
	printf '\n'
	emit_assoc_path_parts_bash "linked_current_pwd_parts" "$PWD"
	printf '\n'
	emit_assoc_path_parts_bash "linked_symlink_parts" "$SYMLINK_PATH"
	printf '\n'
	emit_assoc_path_parts_bash "linked_source_parts" "$SOURCE_ABS"
	printf '\n'
	emit_assoc_path_parts_bash "linked_source_with_prefix_parts" "$SOURCE_WITH_PREFIX"
	printf '\n'
	emit_assoc_path_parts_bash "linked_prefix_parts" "$PREFIX"
	printf '\n'
	emit_assoc_path_parts_bash "linked_shared_prefix_parts" "$SHARED_PREFIX"
	printf '\n'
	emit_assoc_path_parts_bash "linked_link_branch_parts" "$LINK_BRANCH_DIR"
	printf '\n'
	emit_assoc_path_parts_bash "linked_source_branch_parts" "$SOURCE_BRANCH_DIR"
}

