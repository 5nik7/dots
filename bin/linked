		"%l" "$(format_path "$SYMLINK_PATH")" \
		"%d" "$(format_path "$SYMLINK_DIRNAME")" \
		"%b" "$SYMLINK_BASENAME" \
		"%p" "$PREFIX" \
		"%s" "$(format_path "$SOURCE_ABS")" \
		"%D" "$(format_path "$SOURCE_DIRNAME")" \
		"%B" "$SOURCE_BASENAME" \
		"%P" "$(format_path "$SOURCE_WITH_PREFIX")" \
		"%c" "$(format_path "$SHARED_PREFIX")" \
