}

print_arrays() {
	local shell

	shell=$(detect_array_shell)
	validate_array_shell "$shell"

	case $shell in
		bash)
			print_arrays_bash
			;;
		zsh)
			print_arrays_zsh
			;;
		*)
			printf 'linked: unsupported array shell: %s\n' "$shell" >&2
			exit 2
			;;
	esac
}

render_format() {
	local fmt=$1
	local out

	local l d b p
	local s D B P
	local c e E m

	l=$(format_path "$SYMLINK_PATH")
	d=$(format_path "$SYMLINK_DIRNAME")
	b=$SYMLINK_BASENAME
	p=$PREFIX

	s=$(format_path "$SOURCE_ABS")
	D=$(format_path "$SOURCE_DIRNAME")
	B=$SOURCE_BASENAME
	P=$(format_path "$SOURCE_WITH_PREFIX")

	c=$(format_path "$SHARED_PREFIX")
	e=$LINK_BRANCH_DIR
	E=$SOURCE_BRANCH_DIR
	m=$SHARED_BASENAME

	out=$fmt

	out=${out//%%/$'\001'}

	out=${out//%l/$l}
	out=${out//%d/$d}
	out=${out//%b/$b}
	out=${out//%p/$p}

	out=${out//%s/$s}
	out=${out//%D/$D}
	out=${out//%B/$B}
	out=${out//%P/$P}

	out=${out//%c/$c}
	out=${out//%e/$e}
	out=${out//%E/$E}
	out=${out//%m/$m}

	out=${out//$'\001'/%}

	printf '%s\n' "$out"
}

RAW=0
MODE="full"
FORMAT_STRING=""
ARRAY_SHELL="auto"
TARGET_ARG_PROVIDED=0
TARGET_INPUT=""
TARGET_PATH=""
TARGET_PATH_PHYSICAL=""

while (($#)); do
	case $1 in
		--)
			shift

			if (($# > 1)); then
				printf 'linked: too many path arguments\n' >&2
				exit 2
			fi

			if (($# == 1)); then
				if (( TARGET_ARG_PROVIDED )); then
					printf 'linked: too many path arguments\n' >&2
					exit 2
				fi

				TARGET_ARG_PROVIDED=1
				TARGET_INPUT=$1
			fi

			break
			;;
		--full)
			MODE="full"
			;;
		-d|--dirname)
			MODE="dirname"
			;;
		-b|--basename)
			MODE="basename"
			;;
		-p|--prefix)
			MODE="prefix"
			;;
		-s|--source)
			MODE="source"
			;;
		-D|--source-dirname)
			MODE="source_dirname"
			;;
		-B|--source-basename)
			MODE="source_basename"
			;;
		-C|--shared-prefix)
			MODE="shared_prefix"
			;;
		-e|--link-branch-dir)
			MODE="link_branch_dir"
			;;
		-E|--source-branch-dir)
			MODE="source_branch_dir"
			;;
		-m|--shared-basename)
			MODE="shared_basename"
			;;
		-f|--format)
			shift

			if (($# == 0)); then
				printf 'linked: missing format string for -f|--format\n\n' >&2
				usage >&2
				exit 2
			fi

			MODE="format"
			FORMAT_STRING=$1
			;;
		--format=*)
			MODE="format"
			FORMAT_STRING=${1#*=}
			;;
		-j|--json)
			MODE="json"
			;;
		-A|--arrays|--array)
			MODE="arrays"

			if (($# > 1)); then
				case $2 in
					auto|bash|zsh)
						ARRAY_SHELL=$2
						shift
						;;
				esac
			fi
			;;
		--arrays=*|--array=*)
			MODE="arrays"
			ARRAY_SHELL=${1#*=}
			validate_array_shell "$ARRAY_SHELL"
			;;
		-r|--raw)
			RAW=1
			;;
		--completion)
			shift

			if (($# == 0)); then
				printf 'linked: missing shell for --completion\n' >&2
				printf 'linked: expected one of: bash, zsh\n' >&2
				exit 2
			fi

			print_completion "$1"
			exit 0
			;;
		--completion=*)
			print_completion "${1#*=}"
			exit 0
			;;
		-h|--help)
			usage
			exit 0
			;;
		-*)
			printf 'linked: unknown option: %s\n\n' "$1" >&2
			usage >&2
			exit 2
			;;
		*)
			if (( TARGET_ARG_PROVIDED )); then
				printf 'linked: too many path arguments: %s\n' "$1" >&2
				exit 2
			fi

			TARGET_ARG_PROVIDED=1
			TARGET_INPUT=$1
			;;
	esac

	shift
done

validate_array_shell "$ARRAY_SHELL"

if (( TARGET_ARG_PROVIDED )); then
	prepare_target_path "$TARGET_INPUT"
else
	TARGET_INPUT=$PWD
	prepare_target_path "$TARGET_INPUT"
fi

if ! find_deepest_symlink_in_path "$TARGET_PATH"; then
	printf 'linked: no symlink component found in path: %s\n' "$TARGET_PATH" >&2
	exit 1
fi

SYMLINK_DIRNAME=$(dirname -- "$SYMLINK_PATH")
SYMLINK_BASENAME=$(basename -- "$SYMLINK_PATH")
PREFIX=$(build_prefix_from_index "$SYMLINK_INDEX" "$TARGET_PATH")

LINK_TARGET=$(readlink -- "$SYMLINK_PATH")
SOURCE_ABS=$(abspath "$LINK_TARGET" "$(dirname -- "$SYMLINK_PATH")")
SOURCE_ABS=$(normalize_path "$SOURCE_ABS")
SOURCE_DIRNAME=$(dirname -- "$SOURCE_ABS")
SOURCE_BASENAME=$(basename -- "$SOURCE_ABS")
SOURCE_WITH_PREFIX=$(join_path_and_prefix "$SOURCE_ABS" "$PREFIX")

SHARED_PREFIX=$(common_prefix_path "$SYMLINK_PATH" "$SOURCE_ABS")
LINK_BRANCH_DIR=$(relative_after_prefix "$SYMLINK_DIRNAME" "$SHARED_PREFIX")
SOURCE_BRANCH_DIR=$(relative_after_prefix "$SOURCE_DIRNAME" "$SHARED_PREFIX")

if [[ $SYMLINK_BASENAME == "$SOURCE_BASENAME" ]]; then
	BASES_MATCH=1
	SHARED_BASENAME=$SYMLINK_BASENAME
else
	BASES_MATCH=0
	SHARED_BASENAME=""
fi

case $MODE in
	full)
		print_path "$SYMLINK_PATH"
		;;
	dirname)
		print_path "$SYMLINK_DIRNAME"
		;;
	basename)
		printf '%s\n' "$SYMLINK_BASENAME"
		;;
	prefix)
		printf '%s\n' "$PREFIX"
		;;
	source)
		print_path "$SOURCE_ABS"
		;;
	source_dirname)
		print_path "$SOURCE_DIRNAME"
		;;
	source_basename)
		printf '%s\n' "$SOURCE_BASENAME"
		;;
	shared_prefix)
		print_path "$SHARED_PREFIX"
		;;
	link_branch_dir)
		printf '%s\n' "$LINK_BRANCH_DIR"
		;;
	source_branch_dir)
		printf '%s\n' "$SOURCE_BRANCH_DIR"
		;;
	shared_basename)
		printf '%s\n' "$SHARED_BASENAME"
		;;
	format)
		render_format "$FORMAT_STRING"
		;;
	json)
		print_json
		;;
	arrays)
		print_arrays
		;;
esac