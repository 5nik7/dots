#!/usr/bin/env bash
set -o pipefail

declare -r esc=$'\033'
declare -r c_reset="${esc}[0m"
declare -r c_red="${esc}[31m"
declare -r c_green="${esc}[32m"
declare -r c_yellow="${esc}[33m"
declare -r c_blue="${esc}[34m"
declare -r c_black="${esc}[30m"

err() { printf "${c_red}%s${c_reset}\n" "$*" >&2; }
die() {
  err "$*"
  exit 1
}

path_display() {
  local p=$1
  if ((raw)); then
    printf '%s\n' "$p"
  else
    case "$p" in
    "$HOME")
      printf '~\n'
      ;;
    "$HOME"/*)
      printf '~/%s\n' "${p#"$HOME"/}"
      ;;
    *)
      printf '%s\n' "$p"
      ;;
    esac
  fi
}

usage() {
  local prog=${0##*/}
  cat <<-eof
$prog - for your dotfilea
  -h --help    display this help message
eof
}

main() {
  while (($#)); do
    case $1 in
    -r | --raw)
      raw=1
      ;;
    -d | --dir)
      path_display "$DOTS"
      exit 0
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      err "unknown option: %s\n\n" "$1"
      usage >&3
      exit 1
      ;;
    esac
    shift
  done
  usage
  exit 0
}

main "$@"
