#!/bin/bash

export REPOS="$HOME/repos"
export DOTS="$REPOS/dots"
export DOTFILES=${DOTFILES:="$HOME/.dotfiles"}
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

ORANGE="\033[38;5;216m"
PURPLE="\033[38;5;140m"
GRAY="\033[0;30m"
WHITE="\033[0;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
BLUE="\033[0;34m"
YELLOW="\033[0;33m"
CYAN="\033[0;36m"
PINK="\033[0;35m"
GRAYB="\033[1;30m"
WHITEB="\033[1;37m"
REDB="\033[1;31m"
BLUEB="\033[1;34m"
GREENB="\033[1;32m"
YELLOWB="\033[1;33m"
CYANB="\033[1;36m"
PINKB="\033[1;35m"

NC="\033[0m"

HEADER="${GREENB}"
LINECOLOR="${GRAYB}"
PANELBG="\033[48;5;233m"
menu_symbol="ůįÖā"
solsymble="ÔďÉ"

cecho(){
    printf "${(P)1}${2} ${NC}\n"
}

logo() {
	topdoubleline
	echo -e "${LINECOLOR}\033[48;5;234m‚ēĎ${HEADER}                                        ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;233m‚ēĎ${HEADER}    ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ   ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ  ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ    ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;233m‚ēĎ${HEADER}    ‚Ėí‚Ėí   ‚Ėí‚Ėí ‚Ėí‚Ėí    ‚Ėí‚Ėí      ‚Ėí‚Ėí ‚Ėí‚Ėí         ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;232m‚ēĎ${HEADER}    ‚Ėí‚Ėí   ‚Ėí‚Ėí ‚Ėí‚Ėí    ‚Ėí‚Ėí    ‚Ėí‚Ėí   ‚Ėí‚Ėí‚Ėí‚Ėí‚Ėí‚Ėí‚Ėí    ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;232m‚ēĎ${HEADER}    ‚Ėď‚Ėď   ‚Ėď‚Ėď ‚Ėď‚Ėď    ‚Ėď‚Ėď   ‚Ėď‚Ėď         ‚Ėď‚Ėď    ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;016m‚ēĎ${HEADER}    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą    ‚Ėą‚Ėą    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą    ${LINECOLOR}‚ēĎ${NC}"
	echo -e "${LINECOLOR}\033[48;5;016m‚ēĎ${HEADER}                                        ${LINECOLOR}‚ēĎ${NC}"
   bottomdoubleline
}

menu() {
	menutitle		"OPTIONS                              "
	linelinebreak
	menuopt			"setup                              "
	menuopt			"link                               "
	menuopt			"update                             "
	linelinebreak
	bottomline
}

menutitle() {
	topline
	echo -e "${LINECOLOR}${PANELBG}‚ēĎ  ${BLUEB}$1 ${LINECOLOR}‚ēĎ${NC}"
	middleline
}

title() {
	topline
	echo -e "${LINECOLOR}${PANELBG}‚ēĎ  ${BLUEB}$1 ${LINECOLOR}‚ēĎ${NC}"
	bottomline
}

menuopt() {
	echo -e "${LINECOLOR}${PANELBG}‚ēĎ  ${GRAY}${PANELBG}${menu_symbol} ${PINKB}$1 ${LINECOLOR}‚ēĎ${NC}"
}

topline() {
	echo -e "${LINECOLOR}${PANELBG}‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó${NC}"
}


middleline() {
	echo -e "${LINECOLOR}${PANELBG}‚ē†‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ē£${NC}"
}

bottomline() {
	echo -e "${LINECOLOR}${PANELBG}‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ${NC}"
}

topdoubleline() {
	echo -e "${LINECOLOR}\033[48;5;234m‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēó${NC}"
}

middledoubleline() {
	echo -e "${LINECOLOR}${PANELBG}‚ē†‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ē£${NC}"
}

bottomdoubleline() {
	echo -e "${LINECOLOR}\033[48;5;016m‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ${NC}"
}

texture() {
	echo -e "${LINECOLOR}${solsymble}ůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆůįĒĆ${NC}"
}

linebreak() {
	echo -e ""
}

linelinebreak() {
	echo -e "${LINECOLOR}${PANELBG}‚ēĎ                                        ‚ēĎ${NC}"
}

success() {
	topline
	echo -e "${LINECOLOR}${PANELBG}‚ēĎ   ${GREENB}$1                                ${LINECOLOR}‚ēĎ${NC}"
	bottomline
}

print_default() {
	echo -e "$*"
}

print_info() {
	echo -e "\e[1;36m$*\e[m" # cyan
}

print_notice() {
	echo -e "\e[1;35m$*\e[m" # magenta
}

print_success() {
	echo -e "\e[1;32m$*\e[m" # green
}

print_warning() {
	echo -e "\e[1;33m$*\e[m" # yellow
}

print_error() {
	echo -e "\e[1;31m$*\e[m" # red
}

print_debug() {
	echo -e "\e[1;34m$*\e[m" # blue
}

error() {
	echo -e "    ${COLOR_RED}ÔĄĆ ${NC}$1"
}

warning() {
	echo -e "    ${COLOR_YELLOW}ÔĄĆ ${NC}$1"
}

info() {
	echo -e "    ${BLUE}ÔĄĆ ${NC}$1"
}
fold1() {
    cecho "BLUE" $(basename "$1")
}

fold2() {
    echo -e $(basename "$(dirname "$1")")/$(basename "$1")
}

fold3() {
    echo -e $(basename "$(dirname "$(dirname "$1")")")/$(basename "$(dirname "$1")")/$(basename "$1")
}

setup_zsh() {
	if [[ ! $SHELL = "/usr/bin/zsh" ]]; then
		title "Setting up ZSH.                      "
		sudo apt -qq install zsh -y
		setshell
	fi
}

ask(){
	while true; do
		read -rp " Start the setup? [Y/n]: " yn
			case $yn in
				[Yy]* ) break;;
				[Nn]* ) exit;;
				* ) break;;
			esac
  		done
	clear
}



createdir() {
	if [ ! -d "$1" ]; then
		mkdir -p "$1"
		echo -e "${LINECOLOR}${solsymble}${NC} ${BLUE}Created${NC} ${CYANB}$1${NC}"
	fi
}

take() {
	if [ ! -d "$2" ]; then
		git clone "https://github.com/$1.git" "$2"
		echo -e "${LINECOLOR}${solsymble}${NC} ${PURPLE}Github.com/${NC}${PINKB}$1 ${GRAY}->${NC} ${CYANB}$2${NC}"
	fi
}

link_bin() {
	if [ ! -e "$HOME/.local/bin/$2" ]; then
			ln -s $(which $1) $HOME/.local/bin/$2
	fi
}

symlink() {
	if [ ! -e "$2" ]; then
		ln -s "$1" "$2"
		echo -e "${LINECOLOR}${solsymble}${NC}  ${BLUE}$1${NC} ${GRAY}->${NC} ${CYANB}$2${NC}"
	else
		echo -e "${LINECOLOR}${solsymble}${NC}  ${GRAYB}$2${NC} ${GRAY}already exists${NC}"
	fi
}

backup() {
	if [ -f "$1" ]; then
		mv -f "$1" "${1}.bak"
		echo -e "${LINECOLOR}${solsymble}${NC}  ${ORANGE}$1${NC} ${GRAY}->${NC} ${YELLOWB}$1.bak${NC}"
	else
		echo -e "${LINECOLOR}${solsymble}${NC}  ${PINKB}$1${NC} ${PINK}does not exist${NC}"
	fi
}

is_installed() {
	dpkg -s "$1" &>/dev/null
	return $?
}

installpkg() {
  if ! is_installed "$1"; then
			sudo apt -qq install "$1" -y
			echo -e "${LINECOLOR}${solsymble}${NC}  ${CYANB}$1${NC} ${BREENB}installed${NC}"
		else
			echo -e "${LINECOLOR}${solsymble}${NC}  ${GRAYB}$1${NC} ${GRAY}already installed${NC}"
		fi
}

installnala() {
	if ! is_installed "nala"; then
		sudo apt -qq install nala -y
	fi
}

installthorium() {
	if ! is_installed "thorium-browser"; then
		wget https://dl.thorium.rocks/debian/dists/stable/thorium.list
		sudo mv thorium.list /etc/apt/sources.list.d/
		sudo apt update -y
		sudo apt install thorium-browser -y
	fi
}

installpkgs() {
  for pkgs in ${deps[@]}; do
		installpkg "$pkgs"
	done
}

installrustup() {
	if [ ! -d "$HOME/.rustup" ]; then
		curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
	fi
}

installstarship() {
	if ! command -v starship >/dev/null 2>&1; then
		curl -sS https://starship.rs/install.sh | sh
	fi
}

installbob() {
	if [ ! -f "$HOME/.cargo/bin/bob" ]; then
		cargo install --git https://github.com/MordechaiHadad/bob.git
	fi
}

setshell() {
	if [[ $SHELL != "/usr/bin/zsh" ]]; then
  		info "Changing shell to zsh."
  		chsh -s /usr/bin/zsh
	fi
}

install_fonts() {
 createdir "$HOME/.local/share"
	symlink "$REPOS/dots/local/fonts" "$HOME/.local/share/fonts"
	fc-cache -r
}

