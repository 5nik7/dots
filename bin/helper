#!/bin/bash

ORANGE="\033[38;5;216m"
PURPLE="\033[38;5;140m"
GRAY="\033[0;30m"
WHITE="\033[0;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
BLUE="\033[0;34m"
YELLOW="\033[0;33m"
CYAN="\033[0;36m"
PINK="\033[0;35m"
GRAYB="\033[1;30m"
WHITEB="\033[1;37m"
REDB="\033[1;31m"
BLUEB="\033[1;34m"
GREENB="\033[1;32m"
YELLOWB="\033[1;33m"
CYANB="\033[1;36m"
PINKB="\033[1;35m"

NC="\033[0m"

HEADER="${GREENB}"
LINECOLOR="${GRAYB}"
PANELBG="\033[48;5;233m"
menu_symbol=" "
solsymble="  "

cecho(){
    printf "${(P)1}${2} ${NC}\n"
}

logo() {
	topdoubleline
	echo -e "${LINECOLOR}\033[48;5;234mв•‘${HEADER}                                        ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;233mв•‘${HEADER}    в–‘в–‘в–‘в–‘в–‘в–‘   в–‘в–‘в–‘в–‘в–‘в–‘  в–‘в–‘в–‘в–‘в–‘в–‘в–‘ в–‘в–‘в–‘в–‘в–‘в–‘в–‘    ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;233mв•‘${HEADER}    в–’в–’   в–’в–’ в–’в–’    в–’в–’      в–’в–’ в–’в–’         ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;232mв•‘${HEADER}    в–’в–’   в–’в–’ в–’в–’    в–’в–’    в–’в–’   в–’в–’в–’в–’в–’в–’в–’    ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;232mв•‘${HEADER}    в–“в–“   в–“в–“ в–“в–“    в–“в–“   в–“в–“         в–“в–“    ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;016mв•‘${HEADER}    в–€в–€в–€в–€в–€в–€   в–€в–€в–€в–€в–€в–€    в–€в–€    в–€в–€в–€в–€в–€в–€в–€    ${LINECOLOR}в•‘${NC}"
	echo -e "${LINECOLOR}\033[48;5;016mв•‘${HEADER}                                        ${LINECOLOR}в•‘${NC}"
   bottomdoubleline
}

menu() {
	menutitle		"OPTIONS                              "
	linelinebreak
	menuopt			"setup                              "
	menuopt			"link                               "
	menuopt			"update                             "
	linelinebreak
	bottomline
}

menutitle() {
	topline
	echo -e "${LINECOLOR}${PANELBG}в•‘  ${BLUEB}$1 ${LINECOLOR}в•‘${NC}"
	middleline
}

title() {
	topline
	echo -e "${LINECOLOR}${PANELBG}в•‘  ${BLUEB}$1 ${LINECOLOR}в•‘${NC}"
	bottomline
}

menuopt() {
	echo -e "${LINECOLOR}${PANELBG}в•‘  ${GRAY}${PANELBG}${menu_symbol} ${PINKB}$1 ${LINECOLOR}в•‘${NC}"
}

topline() {
	echo -e "${LINECOLOR}${PANELBG}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
}


middleline() {
	echo -e "${LINECOLOR}${PANELBG}в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј${NC}"
}

bottomline() {
	echo -e "${LINECOLOR}${PANELBG}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
}

topdoubleline() {
	echo -e "${LINECOLOR}\033[48;5;234mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
}

middledoubleline() {
	echo -e "${LINECOLOR}${PANELBG}в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј${NC}"
}

bottomdoubleline() {
	echo -e "${LINECOLOR}\033[48;5;016mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
}

linebreak() {
	echo -e ""
}

linelinebreak() {
	echo -e "${LINECOLOR}${PANELBG}в•‘                                        в•‘${NC}"
}

success() {
	topline
	echo -e "${LINECOLOR}${PANELBG}в•‘   ${GREENB}$1                                ${LINECOLOR}в•‘${NC}"
	bottomline
}

cmd_exists() {
    command -v "$1" &> /dev/null
}

print_in_color() {
    printf "%b" \
        "$(tput setaf "$2" 2> /dev/null)" \
        "$1" \
        "$(tput sgr0 2> /dev/null)"
}

print_in_green() {
    print_in_color "$1" 2
}

print_in_purple() {
    print_in_color "$1" 5
}

print_in_red() {
    print_in_color "$1" 1
}

print_in_yellow() {
    print_in_color "$1" 3
}

print_question() {
    print_in_yellow "   [?] $1"
}

print_error() {
    print_in_red "   [вњ–] $1 $2\n"
}

print_success() {
    print_in_green "   [оЄІ] $1\n"
}

print_warning() {
    print_in_yellow "   [!] $1\n"
}

echo_relative_path() {
    echo "$1" | sed "s|^$HOME/||"
}

rel_path() {
    echo "$1" | sed "s|^$HOME/|~/|"
}

fold1() {
    cecho "BLUE" $(basename "$1")
}

fold2() {
    echo -e $(basename "$(dirname "$1")")/$(basename "$1")
}

fold3() {
    echo -e $(basename "$(dirname "$(dirname "$1")")")/$(basename "$(dirname "$1")")/$(basename "$1")
}

setup_zsh() {
	if [[ ! $SHELL = "/usr/bin/zsh" ]]; then
		title "Setting up ZSH.                      "
		sudo apt -qq install zsh -y
		setshell
	fi
}

ask(){
	while true; do
		read -rp " Start the setup? [Y/n]: " yn
			case $yn in
				[Yy]* ) break;;
				[Nn]* ) exit;;
				* ) break;;
			esac
  		done
	clear
}

mkd() {
    if [ -n "$1" ]; then
        if [ -e "$1" ]; then
            if [ ! -d "$1" ]; then
                print_error "$1 - a file with the same name already exists!"
			fi
        else
            mkdir -p $1
			print_success "$1"
        fi
    fi
}

take() {
	if [ ! -d "$2" ]; then
		git clone "https://github.com/$1.git" "$2"
		print_success "$1"
	fi
}

link_bin() {
	if [ ! -e "$HOME/.local/bin/$2" ]; then
			ln -s $(which $1) $HOME/.local/bin/$2
	fi
}

symlink() {
	if [ ! -e "$2" ]; then
		ln -s "$1" "$2"
		echo -e "${LINECOLOR}${solsymble}${NC}  ${BLUE}$1${NC} ${GRAY}->${NC} ${CYANB}$2${NC}"
	else
	relfile=$(rel_path $2)
		print_success "$relfile"
	fi
}

backup() {
	if [ -f "$1" ]; then
		mv -f "$1" "${1}.bak"
		echo -e "${LINECOLOR}${solsymble}${NC}  ${ORANGE}$1${NC} ${GRAY}->${NC} ${YELLOWB}$1.bak${NC}"
	else
		echo -e "${LINECOLOR}${solsymble}${NC}  ${PINKB}$1${NC} ${PINK}does not exist${NC}"
	fi
}

is_installed() {
	dpkg -s "$1" &>/dev/null
	return $?
}

installpkg() {
  if ! is_installed "$1"; then
			sudo apt -qq install "$1" -y
			echo -e "${LINECOLOR}${solsymble}${NC}  ${CYANB}$1${NC} ${BREENB}installed${NC}"
		else
			echo -e "${LINECOLOR}${solsymble}${NC}  ${GRAYB}$1${NC} ${GRAY}already installed${NC}"
		fi
}

installnala() {
	if ! is_installed "nala"; then
		sudo apt -qq install nala -y
	fi
}

installthorium() {
	if ! is_installed "thorium-browser"; then
		wget https://dl.thorium.rocks/debian/dists/stable/thorium.list
		sudo mv thorium.list /etc/apt/sources.list.d/
		sudo apt update -y
		sudo apt install thorium-browser -y
	fi
}

installpkgs() {
  for pkgs in ${deps[@]}; do
		installpkg "$pkgs"
	done
}

installrustup() {
	if [ ! -d "$HOME/.rustup" ]; then
		curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
	fi
}

installstarship() {
	if ! command -v starship >/dev/null 2>&1; then
		curl -sS https://starship.rs/install.sh | sh
	fi
}

installbob() {
	if [ ! -f "$HOME/.cargo/bin/bob" ]; then
		cargo install --git https://github.com/MordechaiHadad/bob.git
	fi
}

setshell() {
	if [[ $SHELL != "/usr/bin/zsh" ]]; then
  		info "Changing shell to zsh."
  		chsh -s /usr/bin/zsh
	fi
}

install_fonts() {
 createdir "$HOME/.local/share"
	symlink "$REPOS/dots/dotfiles/fonts" "$HOME/.local/share/fonts"
	fc-cache -r
}

