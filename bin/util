#!/usr/bin/env bash

. ~/dots/bin/colors || BOLD='' UNDERLINE='' ITALIC='' DIM='' INVERT='' BLINK='' INVIS='' BLACK='' RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' CYAN='' GREY='' BRIGHTBLACK='' BRIGHTRED='' BRIGHTGREEN='' BRIGHTYELLOW='' BRIGHTBLUE='' BRIGHTMAGENTA='' BRIGHTCYAN='' WHITE='' RST=''



err() {
  local erricon=""
  printf "${BOLD}${BRIGHTRED}${erricon} %s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${RED}" }

ok() { printf "${BRIGHTGREEN}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${GREEN}" }

warn() { printf "${BRIGHTYELLOW}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${YELLOW}" }


pathout() {
	local p
  local raw=0
  if [[ $1 == '-r' ]]; then
    raw=1
    shift
  fi
  for p in "$@"; do
    if (( raw )); then
      printf '%s\n' "$p"
    else
		case "$p" in
			"$HOME")
				printf '~\n'
				;;
			"$HOME"/*)
				printf '~/%s\n' "${p#"$HOME"/}"
				;;
			*)
				printf '%s\n' "$p"
				;;
		esac
    fi
  done
}

so() {
  local file
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for file in "$@"; do
    local out=$(pathout $file)
    if [ -f "$file" ]; then
      local icon=$(fileicon $file)
      source "$file"
      ((verbose)) && ok "$icon $out: sourced"
    else
      ((verbose)) && err "$out: not found"
    fi
  done
}

checkdir() {
  local dir
  local verbose=0
  local first=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  if [[ $1 == '-1' ]]; then
    first=1
    shift
  fi
for dir in "$@"; do
  local out=$(pathout $dir)
    if [ -d "$dir" ]; then
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: found"
      ((first)) && return 0
    else
      ((verbose)) && err "$dir: not found"
    fi
  done
  return 1
}

addir() {
  local dir
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for dir in "$@"; do
    local out=$(pathout $dir)
    if [ ! -e "$dir" ]; then
      mkdir -p "$dir" &>/dev/null
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: created"
    else
      local icon=$(fileicon $dir)
      ((verbose)) && warn "$out: already exists"
    fi
  done
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

cmd_exists() {
 local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

is_installed() {
  dpkg -s "$1" &>/dev/null
  return $?
}

if has eza; then
  fileicon() {
    eza --icons=always --treat-dirs-as-files $@ | awk '{print $1}'
  }
fi

upper() { echo "${@}" | awk '{print toupper($0)}'; }
lower() { echo "${@}" | awk '{print tolower($0)}'; }


timestamp(){
    printf "%s" "$(date '+%F %T')  $*"
    [ $# -gt 0 ] && printf '\n'
}

timestampcmd(){
    local output
    output="$("$@" 2>&1)"
    timestamp "$output"
}

alias sshconfig="vim ~/.ssh/configs"

alias sshcompile="echo -n >! ~/.ssh/config && cat
~/.ssh/configs/*.config >> ~/.ssh/config && cat ~/.ssh/configs/default
>> ~/.ssh/config"

alias ssh="sshcompile && ssh"

# vim: set noet ft=bash tw=4 sw=4 ff=unix
