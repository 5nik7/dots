#!/usr/bin/env bash


extpath() {
	if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
      export PATH="$PATH:$1"
    fi
  fi 2> /dev/null
}

prepath() {
	if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
		  export PATH="$1:$PATH"
	  fi
  fi 2> /dev/null
}

err() {
  local erricon=""
  printf "${BOLD}${BRIGHTRED}${erricon} %s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${RED}" }

ok() { printf "${BRIGHTGREEN}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${GREEN}" }

warn() { printf "${BRIGHTYELLOW}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${YELLOW}" }

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

if has eza; then
  fileicon() {
    eza --icons=always --treat-dirs-as-files $@ | awk '{print $1}'
  }
else
  fileicon() {}
fi

pathout() {
	local p
  local raw=0
  if [[ $1 == '-r' ]]; then
    raw=1
    shift
  fi
  for p in "$@"; do
    if (( raw )); then
      printf '%s\n' "$p"
    else
		case "$p" in
			"$HOME")
				printf '~\n'
				;;
			"$HOME"/*)
				printf '~/%s\n' "${p#"$HOME"/}"
				;;
			*)
				printf '%s\n' "$p"
				;;
		esac
    fi
  done
}


shellmod() {
  local filename
  local shell=$(basename $(echo $SHELL))
  local exists=0
  local verbose=0
  local first=0

 ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
    ;;
    -1 | --first)
      first=1
      shift
      ;;
    * ) break ;;
    esac
  done
  for filename in "$@"; do
    local modfile="$DOTS/shells/$shell/$filename.$shell"
    local out=$(pathout $modfile)
    if [[ -f "$modfile" ]]; then
      exists+=1
      local icon=$(fileicon $modfile)
      source "$modfile"
      ((verbose)) && ok "$icon $out: sourced"
      ((first)) && return 0
    else
      ((verbose)) && err "$out: not found"
    fi
    done
    ((exists >= 1)) && return 0
    return 1
}

alias zieces="shellmod"
alias zmod="shellmod"


so() {
  local file
  local exists=0
  local verbose=0
  local first=0

 ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
    ;;
    -1 | --first)
      first=1
      shift
      ;;
    * ) break ;;
    esac
  done
  for file in "$@"; do
    if [[ -f "$file" ]]; then
      exists+=1
      local icon=$(fileicon $file)
      local out=$(pathout $file)
      source "$file"
      ((verbose)) && ok "$icon $out: sourced"
      ((first)) && return 0
    else
      ((verbose)) && err "$file: not found"
    fi
    done
    ((exists >= 1)) && return 0
    return 1
}

check() {
  local input
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
    ;;
    -1 | --first)
      first=1
      shift
      ;;
    * ) break ;;
    esac
  done
for input in "$@"; do
  if [[ -e "$input" ]]; then
    exists+=1
    local out=$(pathout $input)
    local icon=$(fileicon $dir)
    ((verbose)) && ok "$icon $out: found"
    ((first)) && return 0
  else
  ((verbose)) && err "$input: not found"
  fi
  done
  ((exists >= 1)) && return 0
  return 1
}

checkdir() {
  local dir
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
    ;;
    -1 | --first)
      first=1
      shift
      ;;
    * ) break ;;
    esac
  done
    for dir in "$@"; do
    if [[ -d "$dir" ]]; then
      exists+=1
      local out=$(pathout $dir)
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: found"
      ((first)) && return 0
    else
      ((verbose)) && err "$dir: not found"
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

addir() {
  local dir
  local verbose=0

  ((buggin)) && verbose=1

  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for dir in "$@"; do
    local out=$(pathout $dir)
    if [ ! -e "$dir" ]; then
      mkdir -p "$dir" &>/dev/null
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: created"
    else
      local icon=$(fileicon $dir)
      ((verbose)) && warn "$out: already exists"
    fi
  done
}

has() {
  local verbose=0

  ((buggin)) && verbose=1

  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

cmd_exists() {
 local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

is_installed() {
  dpkg -s "$1" &>/dev/null
  return $?
}

upper() { echo "${@}" | awk '{print toupper($0)}'; }
lower() { echo "${@}" | awk '{print tolower($0)}'; }

timestamp(){
    printf "%s" "$(date '+%F %T')  $*"
    [ $# -gt 0 ] && printf '\n'
}

timestampcmd(){
    local output
    output="$("$@" 2>&1)"
    timestamp "$output"
}

