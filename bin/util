#!/usr/bin/env bash

extpath() {
  if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
      export PATH="$PATH:$1"
    fi
  fi 2>/dev/null
}

prepath() {
  if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
      export PATH="$1:$PATH"
    fi
  fi 2>/dev/null
}

err() {
  local parts line
  local sep='|'
  local erricon="✕"

  for line in "$@"; do
    IFS=$sep read -r parts <<<"$line"
    parts=($RED"${parts[@]}"$RED)
    printf '%s%s%s\n' "$RED$erricon" "$sep" "${parts[@]}"

  done | box -hp 1 -bc "${DIM}${DARKRED}" -s $sep
}

ok() {
  local parts line
  local sep='|'
  local okicon=""

  for line in "$@"; do
    IFS=$sep read -r parts <<<"$line"
    parts=($GREEN"${parts[@]}"$GREEN)
    printf '%s%s%s\n' "$GREEN$okicon" "$sep" "${parts[@]}"
  done | box -hp 1 -bc "${DIM}${DARKGREEN}" -s $sep
}

warn() {
  local parts line
  local sep='|'
  local warnicon=""

  for line in "$@"; do
    IFS=$sep read -r parts <<<"$line"
    parts=($YELLOW"${parts[@]}"$YELLOW)
    printf '%s%s%s\n' "$YELLOW$warnicon" "$sep" "${parts[@]}"
  done | box -hp 1 -bc "${DIM}${YELLOW}" -s $sep
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

fileicon() {
  local icon=''
  if has eza; then
    icon=$(eza --treat-dirs-as-files --icons=always --color=always "$@" 2>/dev/null | cut -d ' ' -f 1 || printf '')
  fi
  printf '%s\n' "$icon"
}

filename() {
  local base
  if has eza; then
    base=$(basename -a "$(eza --treat-dirs-as-files --color=always "$@" 2>/dev/null)" || basename -a "$@")
  fi
  printf '%s\n' "$base"
}

pathout() {
  local p
  local raw=0
  if [[ $1 == '-r' ]]; then
    raw=1
    shift
  fi
  for p in "$@"; do
    if ((raw)); then
      printf '%s\n' "$p"
    else
      case "$p" in
      "$HOME")
        printf '~\n'
        ;;
      "$HOME"/*)
        printf '~/%s\n' "${p#"$HOME"/}"
        ;;
      *)
        printf '%s\n' "$p"
        ;;
      esac
    fi
  done
}

dirout() {
  local p slash color reset
  local raw=0
  while (($#)); do
    case $1 in
    -r | --raw)
      raw=1
      shift
      ;;
    -j | --join)
      slash='/'
      shift
      ;;
    -c | --color)
      color="$BLUE"
      reset="$RST"
      shift
      ;;
    *) break ;;
    esac
  done
  if [[ $# -eq 0 ]]; then
    set -- "$PWD"
  fi
  for p in "$@"; do
    p=$(dirname "$p")
    if ((raw)); then
      printf '%s%s%s%s\n' "$color" "$p" "$slash" "$reset"
    else
      case "$p" in
      "$HOME")
        printf '%s~%s%s\n' "$color" "$slash" "$reset"
        ;;
      "$HOME"/*)
        printf '%s~/%s%s%s\n' "$color" "${p#"$HOME"/}" "$slash" "$reset"
        ;;
      *)
        printf '%s%s%s%s\n' "$color" "$p" "$slash" "$reset"
        ;;
      esac
    fi
  done
}

shell() {
  ps | grep $(echo $$) | awk '{ print $4 }'
}

shellmod() {
  local filename icon dir base
  local shell=$(basename $(shell))
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for filename in "$@"; do
    local modfile="$DOTS/shells/$shell/$filename.$shell"
    if [[ -f "$modfile" ]]; then
      exists+=1
      source "$modfile"
      if ((verbose)); then
        icon=$(fileicon $modfile)
        dir=$(dirout -c -j $modfile)
        base=$(filename $modfile)
        ok "sourced|$icon $dir$base"
      fi
      ((first)) && return 0
    else
      if ((verbose)); then
        dir=$(dirout -j $modfile)
        base=$(basename $modfile)
        err "$dir$base|not found"
      fi
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

alias zieces="shellmod"

so() {
  local file icon dir base
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for file in "$@"; do
    if [[ -f "$file" ]]; then
      exists+=1
      source "$file"
      if ((verbose)); then
        icon=$(fileicon $file)
        dir=$(dirout -c -j $file)
        base=$(filename $file)
        ok "sourced|$icon $dir$base"
      fi
      ((first)) && return 0
    else
      if ((verbose)); then
        dir=$(dirout -j $file)
        base=$(basename $file)
        err "$dir$base|not found"
      fi
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

check() {
  local input icon dir base
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for input in "$@"; do
    if [[ -e "$input" ]]; then
      exists+=1
      if ((verbose)); then
        icon=$(fileicon $input)
        dir=$(dirout -c -j $input)
        base=$(filename $input)
        ok "found|$icon $dir$base"
      fi
      ((first)) && return 0
    else
      if ((verbose)); then
        dir=$(dirout -j $input)
        base=$(basename $input)
        err "$dir$base|not found"
      fi
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

checkdir() {
  local input icon dir base
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for input in "$@"; do
    if [[ -d "$input" ]]; then
      exists+=1
      if ((verbose)); then
        icon=$(fileicon $input)
        dir=$(dirout -c -j $input)
        base=$(filename $input)
        ok "found|$icon $dir$base"
      fi
      ((first)) && return 0
    else
      if ((verbose)); then
        dir=$(dirout -j $input)
        base=$(basename $input)
        err "$dir$base|not found"
      fi
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

addir() {
  local dir
  local verbose=0

  ((buggin)) && verbose=1

  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for dir in "$@"; do
    local out=$(pathout $dir)
    if [ ! -e "$dir" ]; then
      mkdir -p "$dir" &>/dev/null
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: created"
    else
      local icon=$(fileicon $dir)
      ((verbose)) && warn "$out: already exists"
    fi
  done
}

cmd_exists() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

is_installed() {
  dpkg -s "$1" &>/dev/null
  return $?
}

upper() { echo "${@}" | awk '{print toupper($0)}'; }
lower() { echo "${@}" | awk '{print tolower($0)}'; }

getextension() {
  echo "Full filename: $(basename ${1})"
  echo "Extension: ${1##*.}"
  echo "without extension: ${1%.*}"
}

timestamp() {
  printf "%s" "$(date '+%F %T')  $*"
  [ $# -gt 0 ] && printf '\n'
}

timestampcmd() {
  local output
  output="$("$@" 2>&1)"
  timestamp "$output"
}

compact() {
  if [ "$#" -ge "1" ]; then
    case "$1" in
    *.[tT][aA][rR].[bB][zZ] | *.[tT][bB][zZ])
      local file="$1"
      shift
      tar jcvf "$file" "$@"
      ;;
    *.[tT][aA][rR].[bB][zZ]2 | *.[tT][bB][zZ]2)
      local file="$1"
      shift
      tar jcvf "$file" "$@"
      ;;
    *.[tT][aA][rR].[gG][zZ] | *.[tT][gG][zZ])
      local file="$1"
      shift
      tar zcvf "$file" "$@"
      ;;
    *.[gG][tT][gG][zZ])
      local file="$1"
      shift
      tar zcvf "$file" "$@"
      ;;
    *[bB][zZ]2)
      shift
      bzip2 -z -k "$@"
      ;;
    *.[rR][aA][rR])
      local file="$1"
      shift
      rar a -r "$file" "$@"
      ;;
    *[gG][zZ])
      shift
      gzip -r "$@"
      ;;
    *.[tT][aA][rR])
      local file="$1"
      shift
      tar cvf "$file" "$@"
      ;;
    *.[zZ][iI][pP])
      local file="$1"
      shift
      zip -r "$file" "$@"
      ;;
    *.7[zZ])
      local file="$1"
      shift
      7z a -r "$file" "$@"
      ;;
    *.[xX][zZ])
      local file="$1"
      shift
      tar Jcvf "$file" "$@"
      ;;
    *) echo "don't know how to compact '$i' ..." ;;
    esac
  else
    echo "Insufficient arguments."
  fi
}

extract() {
  for i in "$@"; do
    if [ -f "$i" ]; then
      case "$i" in
      *.[tT][aA][rR].[bB][zZ] | *.[tT][bB][zZ]) tar xjvf "$i" ;;
      *.[tT][aA][rR].[bB][zZ]2 | *.[tT][bB][zZ]2) tar xjvf "$i" ;;
      *.[tT][aA][rR].[gG][zZ] | *.[tT][gG][zZ]) tar xzvf "$i" ;;
      *.[gG][tT][gG][zZ]) tar xzvf "$i" ;;
      *.[bB][zZ]2) bunzip2 "$i" ;;
      *.[rR][aA][rR]) rar x -o+ "$i" ;;
      *.[gG][zZ]) gunzip "$i" ;;
      *.[tT][aA][rR]) tar xvf "$i" ;;
      *.[zZ][iI][pP]) unzip -o "$i" ;;
      *.Z) uncompress "$i" ;;
      *.7[zZ]) 7z x "$i" ;;
      *) echo "don't know how to extract '$i' ..." ;;
      esac
    else
      echo "$i is not a valid file"
    fi
  done
}
