#!/usr/bin/env bash

extpath() {
  if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
      export PATH="$PATH:$1"
    fi
  fi 2>/dev/null
}

prepath() {
  if [[ -d "$1" ]]; then
    if ! echo "$PATH" | tr ":" "\n" | grep -qx "$1"; then
      export PATH="$1:$PATH"
    fi
  fi 2>/dev/null
}

err() {
  local erricon=""
  printf "${RED}%s ${DIM}│ ${RST}${BOLD}${BRIGHTRED}%s${RST}\n" "${erricon}" "$*" | box -hp 1 -bc "${DIM}${RED}"
}

ok() {
  printf "${BRIGHTGREEN}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${GREEN}"
}

warn() {
  printf "${BRIGHTYELLOW}%s${RST}\n" "$*" | box -hp 1 -bc "${DIM}${YELLOW}"
}

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

fileicon() {
  if has eza; then
    eza --icons=always ~-color=always --treat-dirs-as-files "$@" &>/dev/null | awk '{print $1}'
  else
    printf ''
  fi
}

pathout() {
  local p
  local raw=0
  if [[ $1 == '-r' ]]; then
    raw=1
    shift
  fi
  for p in "$@"; do
    if ((raw)); then
      printf '%s\n' "$p"
    else
      case "$p" in
      "$HOME")
        printf '~\n'
        ;;
      "$HOME"/*)
        printf '~/%s\n' "${p#"$HOME"/}"
        ;;
      *)
        printf '%s\n' "$p"
        ;;
      esac
    fi
  done
}

dirout() {
  local p
  local slash
  local raw=0
  if [[ $1 == '-r' ]]; then
    raw=1
    shift
  fi
  if [[ $1 == '-j' ]]; then
    slash='/'
    shift
  fi
  if [[ $# -eq 0 ]]; then
    set -- "$PWD"
  fi
  for p in "$@"; do
    p=$(dirname "$p")
    if ((raw)); then
      printf '%s\n' "$p"
    else
      case "$p" in
      "$HOME")
        printf '~%s\n' "$slash"
        ;;
      "$HOME"/*)
        printf '~/%s%s\n' "${p#"$HOME"/}" "$slash"
        ;;
      *)
        printf '%s%s\n' "$p" "$slash"
        ;;
      esac
    fi
  done
}

shell() {
  ps | grep $(echo $$) | awk '{ print $4 }'
}

shellmod() {
  local filename
  local shell=$(basename $(shell))
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for filename in "$@"; do
    local modfile="$DOTS/shells/$shell/$filename.$shell"
    local out=$(pathout $modfile)
    if [[ -f "$modfile" ]]; then
      exists+=1
      local icon=$(fileicon $modfile)
      source "$modfile"
      ((verbose)) && ok "$icon $out: sourced"
      ((first)) && return 0
    else
      ((verbose)) && err "$out: not found"
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

alias zieces="shellmod"
alias zmod="shellmod"

so() {
  local file
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for file in "$@"; do
    local dir=$(dirout $file)
    local base=$(basename $file)
    if [[ -f "$file" ]]; then
      exists+=1
      local icon=$(fileicon $file)
      source "$file"
      ((verbose)) && ok "$icon $dir/$base: sourced"
      ((first)) && return 0
    else
      ((verbose)) && err "$dir/$base: not found"
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

check() {
  local input
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for input in "$@"; do
    local out=$(pathout $input)
    if [[ -e "$input" ]]; then
      exists+=1
      local icon=$(fileicon $input)
      ((verbose)) && ok "$icon $out: found"
      ((first)) && return 0
    else
      ((verbose)) && err "$out: not found"
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

checkdir() {
  local dir
  local exists=0
  local verbose=0
  local first=0

  ((buggin)) && verbose=1

  while (($#)); do
    case $1 in
    -v | --verboss)
      verbose=1
      shift
      ;;
    -1 | --first)
      first=1
      shift
      ;;
    *) break ;;
    esac
  done
  for dir in "$@"; do
    if [[ -d "$dir" ]]; then
      local out=$(pathout $dir)
      exists+=1
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: found"
      ((first)) && return 0
    else
      ((verbose)) && err "$out: not found"
    fi
  done
  ((exists >= 1)) && return 0
  return 1
}

addir() {
  local dir
  local verbose=0

  ((buggin)) && verbose=1

  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for dir in "$@"; do
    local out=$(pathout $dir)
    if [ ! -e "$dir" ]; then
      mkdir -p "$dir" &>/dev/null
      local icon=$(fileicon $dir)
      ((verbose)) && ok "$icon $out: created"
    else
      local icon=$(fileicon $dir)
      ((verbose)) && warn "$out: already exists"
    fi
  done
}

cmd_exists() {
  local verbose=0
  if [[ $1 == '-v' ]]; then
    verbose=1
    shift
  fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

is_installed() {
  dpkg -s "$1" &>/dev/null
  return $?
}

upper() { echo "${@}" | awk '{print toupper($0)}'; }
lower() { echo "${@}" | awk '{print tolower($0)}'; }

getextension() {
  echo "Full filename: $(basename ${1})"
  echo "Extension: ${1##*.}"
  echo "without extension: ${1%.*}"
}

timestamp() {
  printf "%s" "$(date '+%F %T')  $*"
  [ $# -gt 0 ] && printf '\n'
}

timestampcmd() {
  local output
  output="$("$@" 2>&1)"
  timestamp "$output"
}

compact() {
  if [ "$#" -ge "1" ]; then
    case "$1" in
    *.[tT][aA][rR].[bB][zZ] | *.[tT][bB][zZ])
      local file="$1"
      shift
      tar jcvf "$file" "$@"
      ;;
    *.[tT][aA][rR].[bB][zZ]2 | *.[tT][bB][zZ]2)
      local file="$1"
      shift
      tar jcvf "$file" "$@"
      ;;
    *.[tT][aA][rR].[gG][zZ] | *.[tT][gG][zZ])
      local file="$1"
      shift
      tar zcvf "$file" "$@"
      ;;
    *.[gG][tT][gG][zZ])
      local file="$1"
      shift
      tar zcvf "$file" "$@"
      ;;
    *[bB][zZ]2)
      shift
      bzip2 -z -k "$@"
      ;;
    *.[rR][aA][rR])
      local file="$1"
      shift
      rar a -r "$file" "$@"
      ;;
    *[gG][zZ])
      shift
      gzip -r "$@"
      ;;
    *.[tT][aA][rR])
      local file="$1"
      shift
      tar cvf "$file" "$@"
      ;;
    *.[zZ][iI][pP])
      local file="$1"
      shift
      zip -r "$file" "$@"
      ;;
    *.7[zZ])
      local file="$1"
      shift
      7z a -r "$file" "$@"
      ;;
    *.[xX][zZ])
      local file="$1"
      shift
      tar Jcvf "$file" "$@"
      ;;
    *) echo "don't know how to compact '$i' ..." ;;
    esac
  else
    echo "Insufficient arguments."
  fi
}

extract() {
  for i in "$@"; do
    if [ -f "$i" ]; then
      case "$i" in
      *.[tT][aA][rR].[bB][zZ] | *.[tT][bB][zZ]) tar xjvf "$i" ;;
      *.[tT][aA][rR].[bB][zZ]2 | *.[tT][bB][zZ]2) tar xjvf "$i" ;;
      *.[tT][aA][rR].[gG][zZ] | *.[tT][gG][zZ]) tar xzvf "$i" ;;
      *.[gG][tT][gG][zZ]) tar xzvf "$i" ;;
      *.[bB][zZ]2) bunzip2 "$i" ;;
      *.[rR][aA][rR]) rar x -o+ "$i" ;;
      *.[gG][zZ]) gunzip "$i" ;;
      *.[tT][aA][rR]) tar xvf "$i" ;;
      *.[zZ][iI][pP]) unzip -o "$i" ;;
      *.Z) uncompress "$i" ;;
      *.7[zZ]) 7z x "$i" ;;
      *) echo "don't know how to extract '$i' ..." ;;
      esac
    else
      echo "$i is not a valid file"
    fi
  done
}

