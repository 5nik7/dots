#!/usr/bin/env bash

main() {
  local p slash color reset
  local raw=0
  while (($#)); do
    case $1 in
    -r | --raw)
      raw=1
      shift
      ;;
    -j | --join)
      slash='/'
      shift
      ;;
    -c | --color)
      color="$BLUE"
      reset="$RST"
      shift
      ;;
    *) break ;;
    esac
  done
  if [[ $# -eq 0 ]]; then
    set -- "$PWD"
  fi
  for p in "$@"; do
    p=$(dirname "$p")
    if ((raw)); then
      printf '%s%s%s%s\n' "$color" "$p" "$slash" "$reset"
    else
      case "$p" in
      "$HOME")
        printf '%s~%s%s\n' "$color" "$slash" "$reset"
        ;;
      "$HOME"/*)
        printf '%s~/%s%s%s\n' "$color" "${p#"$HOME"/}" "$slash" "$reset"
        ;;
      *)
        printf '%s%s%s%s\n' "$color" "$p" "$slash" "$reset"
        ;;
      esac
    fi
  done
}

main "$@"
