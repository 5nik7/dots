#!/usr/bin/env bash

declare -r esc=$'\033'
declare -r c_reset="${esc}[0m"
declare -r c_red="${esc}[31m"
declare -r c_green="${esc}[32m"
declare -r c_yellow="${esc}[33m"
declare -r c_blue="${esc}[34m"
declare -r c_black="${esc}[30m"

main() {
  local buggin="$buggin"
  if [ -n "$buggin" ] &>/dev/null; then
    local ts=$(date +"%m-%d-%Y %H:%M:%S")
    local dbug="${c_black}[${c_reset}${c_blue}${ts}${c_reset}${c_black}]${c_reset}${c_yellow}[DEBUG]${c_reset}"
    printf "%s ${c_green}%s${c_reset}\t\n" "$dbug" "$*" >&2
    exit 0
  else
    exit 1
  fi
}

main "$@"
