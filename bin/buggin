#!/usr/bin/env bash

SCRIPTDIR=$(dirname "$(readlink -f "$0")")
. $SCRIPTDIR/colors || exit 1

debug="${YELLOW}"
timestamp="${PEACH}"
nonocolor="$timestamp"
output="${BOLD}"
border="${BLACK}"
bugcolor="${BRIGHTBLACK}"

bugico=' '
#  
title=''
date='%H:%M:%S:'
nano=$(awk '{ printf "%.4f\n", $1}' < <(date +'.%N') | sed "s|\.| |" | awk '{ print $2 }')
fulldatel='%y-%m-%d %H:%M:%S:'

buggin() {
  local bug="${bugcolor}${bugico}${RST}"
  local ts=$(date +"${date}")
  local dbug="${debug}${bug}${RST}"
  local stamp="${timestamp}${ts}${RST}"
  local ns="${nonocolor}${nano}${RST}"
  printf '%s %s%s|%s' "$bug" "$stamp" "$ns" "$*" | box -hp 1 -bc "$border" -t "$title" -tc "$debug" -s '|'
}

if ! (return &>/dev/null); then
  buggin "$@"
fi
