#!/usr/bin/env bash

declare -x ESC=$'\x1b'
declare -x RST=$'\x1b[0m'
declare -x rst=$'\x1b[0m'

color_array() {
  declare -xgA COLOR
  local ESC=$'\x1b'
  local i
  for i in {0..255}; do
	COLOR[$i]=$(printf "${ESC}[38;5;${i}mcolor %d\n" "$i")
  ((j++))
	done
}

fg_array() {
  declare -xgA FG
  local ESC=$'\x1b'
  local i
	for i in {0..255}; do
	FG[$i]=$(printf "${ESC}[38;5;%dm\n" "$i")
  ((j++))
	done
}

bg_array() {
  declare -xgA BG
  local ESC=$'\x1b'
  local i
	for i in {0..255}; do
	BG[$i]=$(printf "${ESC}[48;5;%dm\n" "$i")
  ((j++))
	done
}

build_color_arrays() {
  color_array;
  fg_array;
  bg_array;
}

build_color_arrays

ROSEWATER="${ESC}[38;5;224m"
FLAMINGO="${ESC}[38;5;224m"
PINK="${ESC}[38;5;225m"
MAUVE="${ESC}[38;5;183m"
RED="${ESC}[38;5;211m"
MAROON="${ESC}[38;5;217m"
PEACH="${ESC}[38;5;216m"
YELLOW="${ESC}[38;5;222m"
GREEN="${ESC}[38;5;114m"
TEAL="${ESC}[38;5;116m"
SKY="${ESC}[38;5;116m"
SAPPHIRE="${ESC}[38;5;81m"
BLUE="${ESC}[38;5;111m"
LAVENDER="${ESC}[38;5;147m"
TEXT="${ESC}[38;5;189m"
SUBTEXT1="${ESC}[38;5;146m"
SUBTEXT0="${ESC}[38;5;146m"
OVERLAY2="${ESC}[38;5;103m"
OVERLAY1="${ESC}[38;5;103m"
OVERLAY0="${ESC}[38;5;60m"
SURFACE2="${ESC}[38;5;60m"
SURFACE0="${ESC}[38;5;235m"
BASE="${ESC}[38;5;234m"
MANTLE="${ESC}[38;5;233m"
CRUST="${ESC}[38;5;232m"

declare -x BOLD="$(tput bold 2>/dev/null || printf '')"
declare -x UNDERLINE="$(tput smul 2>/dev/null || printf '')"
declare -x ITALIC="$(tput sitm 2>/dev/null || printf '')"
declare -x DIM="$(tput dim 2>/dev/null || printf '')"
declare -x INVERT="$(tput rev 2>/dev/null || printf '')"
declare -x BLINK="$(tput blink 2>/dev/null || printf '')"
declare -x INVIS="$(tput invis 2>/dev/null || printf '')"
declare -x BLACK="$(tput setaf 0 2>/dev/null || printf '')"
declare -x RED="$(tput setaf 1 2>/dev/null || printf '')"
declare -x GREEN="$(tput setaf 2 2>/dev/null || printf '')"
declare -x YELLOW="$(tput setaf 3 2>/dev/null || printf '')"
declare -x BLUE="$(tput setaf 4 2>/dev/null || printf '')"
declare -x MAGENTA="$(tput setaf 5 2>/dev/null || printf '')"
declare -x CYAN="$(tput setaf 6 2>/dev/null || printf '')"
declare -x GREY="$(tput setaf 7 2>/dev/null || printf '')"
declare -x BRIGHTBLACK="$(tput setaf 8 2>/dev/null || printf '')"
declare -x BRIGHTRED="$(tput setaf 9 2>/dev/null || printf '')"
declare -x BRIGHTGREEN="$(tput setaf 10 2>/dev/null || printf '')"
declare -x BRIGHTYELLOW="$(tput setaf 11 2>/dev/null || printf '')"
declare -x BRIGHTBLUE="$(tput setaf 12 2>/dev/null || printf '')"
declare -x BRIGHTMAGENTA="$(tput setaf 13 2>/dev/null || printf '')"
declare -x BRIGHTCYAN="$(tput setaf 14 2>/dev/null || printf '')"
declare -x WHITE="$(tput setaf 15 2>/dev/null || printf '')"
declare -x rst="$(tput sgr0 2>/dev/null || printf '')"
