#!/usr/bin/env bash

SCRIPTDIR=$(dirname "$(readlink -f "$0")")
. $SCRIPTDIR/colors || exit 1

padding=1
lpad=$(repeat-char " " $padding)
pad=$((padding * 2))

DARKRED="${ESC}[38;2;238;93;134m"

if [[ -n $COLOUMNS ]]; then
  COLUMNS=$COLOUMNS
fi

if [[ -n $HOST ]]; then
  host=$(echo "HOST" | tr '[:upper:]' '[:lower:]')
else
  host=$(hostname -s | tr '[:upper:]' '[:lower:]')
fi

if [[ -n $host ]]; then
  if [[ "$host" == "localhost" ]]; then
    host=$(echo $distro | tr '[:upper:]' '[:lower:]')
  else
    host=$(echo $host | tr '[:upper:]' '[:lower:]')
  fi
else
  host="unknown"
fi

has() {
  command -v "$1" >/dev/null 2>&1
}

in_git() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

git_all() {
  local commitmsg="$1"
  if ((buggin)); then
    buggin "${BLUE}git_all()${RST} | $(pathout $PWD)"
  else
    git add --all && git commit -m "$commitmsg" --quiet && git push --quiet
  fi
}

gitcheck() {
  if mygit; then
    local changed=$(git status -s | awk '{print $2}')
    if [[ -n "$changed" ]]; then
      return 0
    else
      return 1
    fi
  fi
}

gitmodified() {
  if mygit; then
    local modified=$(git status -s | grep -E '^\s*M\s' | awk '{print $2}')
    if [[ -n "$modified" ]]; then
      echo "$modified"
      return 0
    else
      return 1
    fi
  fi
}

gitdeleted() {
  if mygit; then
    local deleted=$(git status -s | grep -E '^\s*D\s' | awk '{print $2}')
    if [[ -n "$deleted" ]]; then
      echo "$deleted"
      return 0
    else
      return 1
    fi
  fi
}

gituntracked() {
  if mygit; then
    local untracked=$(git status -s | grep '??' | awk '{print $2}')
    if [[ -n "$untracked" ]]; then
      echo "$untracked"
      return 0
    else
      return 1
    fi
  fi
}

submodules() {
  local recurse=0
  if in_git; then
    if [[ $1 == '-r' ]]; then
      recurse=1
      shift
    fi
    if ((recurse)); then
      git submodule status --recursive | awk '{print $2}'
    else
      git submodule status | awk '{print $2}'
    fi
  else
    return 1
  fi
}

is_submodule() {
  local submodule
  local submodules=()
  local recurse=0
  if in_git; then
    local cdup=$(git rev-parse --show-cdup)
    if [[ $1 == '-r' ]]; then
      recurse=1
      shift
    fi
    if ((recurse)); then
      submodules=($(git submodule status --recursive | awk '{print $2}'))
    else
      submodules=($(git submodule status | awk '{print $2}'))
    fi
    for submodule in "${submodules[@]}"; do
      if [[ "${cdup}${@}" == "$submodule" ]]; then
        return 0
      else
        return 1
      fi
    done
  else
    return 1
  fi
}

modified() {
  local statpad=$((pad + 4))
  local modified=($(gitmodified))
  if [[ -n "$modified" ]]; then
    local stats=$(git diff --stat --stat-width=$((COLUMNS - statpad)) --color=always | grep "|")
    for mod in "${modified[@]}"; do
      echo "$stats" | grep "$mod" | sed "s|${mod}|${TEXT}${BOLD}${mod}${RST}|"
    done | box -bc $BRIGHTBLACK -hp 1 -t "MODIFIED:" -tc $YELLOW -s '|' | lpad "$lpad"
  fi
}

deleted() {
  local minus="${DARKRED}󰍴${RST}"
  local statpad=$((pad + 4))
  local deleted=$(gitdeleted)
  if [[ -n "$deleted" ]]; then
    local stats=$(git diff --stat --stat-width=$((COLUMNS - statpad)) --color=always | grep "|")
    for del in $(gitdeleted); do
      local dir=$(dirname "$del")
      local base=$(basename "$del")
      local file="${DARKRED}${dir}/${RST}${BOLD}${BRIGHTRED}${base}${RST}"
      echo "$stats" | grep "$del" | sed "s|${del}|${minus} ${file}|"
    done | box -bc $BRIGHTBLACK -hp 1 -t "DELETED:" -tc $BRIGHTRED -s '|' | lpad "$lpad"
  fi
}

untracked() {
  local plus="${GREEN}${RST}"
  local untracked=$(gituntracked)
  if [[ -n "$untracked" ]]; then
    for un in $(gituntracked); do
      if has eza; then
        local file=$(eza --color=always --icons=always "$un" 2>/dev/null)
      else
        local file="${GREEN}${un}${RST}"
      fi
      printf "%s %s\n" "${plus}" "${file}"
    done | box -bc $BRIGHTBLACK -hp 1 -t "UNTRACKED:" -tc $GREEN | lpad "$lpad"
  fi
}

subcheck() {
  local cwd=$PWD
  local subdir="$1"
  local commitmsg="$2"
  local submodules=()
  submodules=($(submodules))
  if [[ -n "$submodules" ]]; then
    for sub in "${submodules[@]}"; do
      cd "$sub"
      subup "$sub" "$commitmsg"
      cd "$cwd"
    done
    subup "$sudir" "$commitmsg"
  else
    subup "$sudir" "$commitmsg"
  fi
}

subup() {
  local subdir="$1"
  local commitmsg="$2"
  if mygit && gitcheck; then
    local subrepo=$(gitsub -f '%B')
    local subbranch=$(git branch | awk '{print $2}')
    echo
    printf "${SUBTEXT}%s ${SKY}%s ${SKY}${BOLD}%s${RST} ${MAUVE}%s${RST}\n" "submodule:" "$ico" "$subrepo" "$branchico$subbranch" | box -hp 1 -bc "${DIM}${SAPPHIRE}" -t "UPDATE" -tc "${SAPPHIRE}" | lpad "$lpad"
    modified
    deleted
    untracked
    git_all "$commitmsg"
  fi
}

repoup() {
  local commitmsg="$1"
  echo
  printf "${SUBTEXT} %s ${SKY}%s ${SKY}${BOLD}%s${RST} ${MAUVE}%s${RST}\n" "repo:" "$ico" "$repo" "$branchico$branch" | box -hp 1 -bc "${DIM}${SAPPHIRE}" -t "UPDATE" -tc "${SAPPHIRE}" | lpad "$lpad"
  modified
  deleted
  untracked
  git_all "$commitmsg"
}

catchup() {
  local behind="$1"
  if [[ "$behind" -gt 0 ]]; then
    git pull --recurse-submodules -q &>/dev/null
  fi
}

main() {
  local buggin=0
  local ts=$(date +"%Y-%m-%d %H:%M")
  local commitmsg="Sync via $host on $ts"
  local cwd
  local branchico=''
  local gitico=''
  local ico repo root branch subdir cdup upstream ahead behind
  local subdirs=()
  if in_git; then
    if mygit; then
      if [[ $1 == '-d' ]]; then
        buggin=1
        shift
      fi
      if [[ -n "$1" ]]; then
        commitmsg="$1 via $host on $ts"
      fi
      upstream=$(git rev-parse --abrev-ref --symbolic-full-name @{upstream} 2>/dev/null)
      ahead=$(git rev-list --left-right --count "$upstream"...HEAD 2>/dev/null | awk '{print $1}')
      behind=$(git rev-list --left-right --count "$upstream"...HEAD 2>/dev/null | awk '{print $2}')
      branch=$(git branch | awk '{print $2}')
      repo=$(git-it -r)
      ico=$(git-it -i)
      cdup=$(git rev-parse --show-cdup)
      root=$(git rev-parse --show-toplevel)
      cwd=$PWD
      if [[ "$root" != "$cwd" ]]; then
        cd "$root"
      fi
      catchup "$behind"
      subdirs=($(submodules))
      for subdir in "${subdirs[@]}"; do
        cd "$subdir"
        subcheck "$subdir" "$commitmsg"
        cd "$root"
      done
      if [[ "$root" != "$cwd" ]]; then
        cd "$root"
      fi
      if gitcheck; then
        repoup "$commitmsg"
        if [[ "$root" != "$cwd" ]]; then
          cd "$cwd"
        fi
      else
        echo
        printf "${YELLOW}%s ${BRIGHTYELLOW}${BOLD}%s${RST}${PEACH} %s${RST}\n" "$ico" "$repo" "up to date." | box -hp 1 -bc "${DIM}${PEACH}" | lpad "$lpad"
      fi
    else
      out="$(pathout $cwd)"
      echo
      printf "${MAROON}%s ${MAROON}${BOLD}%s${RST}${RED} %s${RST}\n" "$gitico" "$out" "not my repo." | box -hp 1 -bc "${DIM}${RED}" | lpad "$lpad"
      return 1
    fi
  else
    out="$(pathout $cwd)"
    echo
    printf "${MAROON}%s ${MAROON}${BOLD}%s${RST}${RED} %s${RST}\n" "$gitico" "$out" "not a repo." | box -hp 1 -bc "${DIM}${RED}" | lpad "$lpad"
    return 1
  fi
}

main "$@"
