#compdef catwalk

autoload -U is-at-least

_catwalk() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-o+[Path to output file]:OUTPUT:_files' \
'--output=[Path to output file]:OUTPUT:_files' \
'-l+[Layout to use]:LAYOUT:(composite stacked grid row)' \
'--layout=[Layout to use]:LAYOUT:(composite stacked grid row)' \
'-r+[Radius of rounded corners (percentage)]:RADIUS:_default' \
'--radius=[Radius of rounded corners (percentage)]:RADIUS:_default' \
'-g+[Size of gaps between pictures for the \`grid\` layout]:GAP:_default' \
'--gap=[Size of gaps between pictures for the \`grid\` layout]:GAP:_default' \
'-C+[Change to <DIRECTORY> before processing files]:DIRECTORY:_files' \
'--directory=[Change to <DIRECTORY> before processing files]:DIRECTORY:_files' \
'--ext=[File extension to use for input files, if they'\''re not explicitly named]:EXTENSION:(webp png)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::latte -- Path to Latte image:_files' \
'::frappe -- Path to Frappé image:_files' \
'::macchiato -- Path to Macchiato image:_files' \
'::mocha -- Path to Mocha image:_files' \
":: :_catwalk_commands" \
"*::: :->catwalk" \
&& ret=0
    case $state in
    (catwalk)
        words=($line[5] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:catwalk-command-$line[5]:"
        case $line[5] in
            (completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_catwalk__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:catwalk-help-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_catwalk_commands] )) ||
_catwalk_commands() {
    local commands; commands=(
'completion:Generates a completion file for the given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'catwalk commands' commands "$@"
}
(( $+functions[_catwalk__subcmd__completion_commands] )) ||
_catwalk__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'catwalk completion commands' commands "$@"
}
(( $+functions[_catwalk__subcmd__help_commands] )) ||
_catwalk__subcmd__help_commands() {
    local commands; commands=(
'completion:Generates a completion file for the given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'catwalk help commands' commands "$@"
}
(( $+functions[_catwalk__subcmd__help__subcmd__completion_commands] )) ||
_catwalk__subcmd__help__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'catwalk help completion commands' commands "$@"
}
(( $+functions[_catwalk__subcmd__help__subcmd__help_commands] )) ||
_catwalk__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'catwalk help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_catwalk" ]; then
    _catwalk "$@"
else
    compdef _catwalk catwalk
fi
