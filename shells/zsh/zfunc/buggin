declare -r esc=$'\033'
declare -r c_reset="${esc}[0m"
declare -r c_red="${esc}[31m"
declare -r c_green="${esc}[32m"
declare -r c_yellow="${esc}[33m"
declare -r c_blue="${esc}[34m"
declare -r c_black="${esc}[30m"

buggin() {
    [[ -z "$BUGGIN" ]] &>/dev/null || {
    local ts=$(date +"%m-%d-%Y %H:%M:%S")
    local dbug="${c_black}[${c_reset}${c_blue}${ts}${c_reset}${c_black}]${c_reset}${c_yellow}[DEBUG]${c_reset}\t"
    printf "%s ${c_green}%s${c_reset}\n" "$dbug" "$*" >&2
  }
}


