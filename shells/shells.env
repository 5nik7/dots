#!/usr/bin/env zsh

export SHELLS="$DOTS/shells"
export ZSH="$SHELLS/zsh"
export BASH="$SHELLS/bash"
export PWSH="$SHELLS/powershell"

declare -x dot[shells]="$SHELLS"
declare -xgA shells
declare -x shells[root]="${SHELLS:-$DOTS/shells}"
declare -x shells[zsh]="$SHELLS/zsh"
declare -x shells[bash]="$SHELLS/bash"
declare -x shells[pwsh]="$SHELLS/powershell"
