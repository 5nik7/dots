#!/usr/bin/env zsh

export DOTRUBY="$DOTS/ruby"
export RUBYCOMP="$DOTRUBY/completion"
declare -xgA ruby
declare -x ruby[root]="$DOTS/ruby"
declare -x ruby[completion]="$DOTRUBY/completion"

fpath=($ruby[completion] $fpath)

prepath "$ruby[completion]"

alias updrbenv='git -C "$(rbenv root)"/plugins/ruby-build pull'
alias sc='script/console'
alias sg='script/generate'
alias sd='script/destroy'
