#!/usr/bin/env bash
set -o pipefail

declare -r esc=$'\033'
declare -r c_reset="${esc}[0m"
declare -r c_red="${esc}[31m"
declare -r c_green="${esc}[32m"
declare -r c_yellow="${esc}[33m"
declare -r c_blue="${esc}[34m"
declare -r c_black="${esc}[30m"

declare distro
declare preview_pos='right:hidden'

usage() {
  LESS=-FEXR less <<'HELP'
pkgsearch [options] [query]
  lists and installs packages from your distro's repositories

  without any arguments pkgsearch will list all available packages from your cache
  note: on Arch Linux you must pass a string to query the AUR
HELP
}

err() { printf "${c_red}%s${c_reset}\n" "$*" >&2; }
die() { err "$*"; exit 1; }

has() {
  local verbose=0
  if [[ $1 == '-v' ]]; then verbose=1; shift; fi
  for c; do
    c="${c%% *}"
    if ! command -v "$c" &>/dev/null; then
      ((verbose)) && err "$c not found"
      return 1
    fi
  done
}

select_from() {
  local cmd='command -v'
  for a; do
    case "$a" in
      -c) cmd="$2"; shift 2 ;;
    esac
  done
  for c; do
    if $cmd "${c%% *}" &>/dev/null; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

fzf() {
  command fzf -e +s --multi --cycle --ansi \
    --bind='Ctrl-X:toggle-preview' \
    --no-hscroll --inline-info \
    --preview-window="$preview_pos" \
    --header='tab: select | Ctrl-X: preview | Ctrl-I: hide/show installed' \
    "$@"
}

install() {
  local pkgs count
  mapfile -t pkgs
  ((${#pkgs[@]} > 0)) || exit 0
  count="${#pkgs[@]} package"
  ((${#pkgs[@]} > 1)) && count+='s'
  printf "installing %s: %s\n" "$count" "${pkgs[*]}"
  # shellcheck disable=SC2086
  $1 "${pkgs[@]}" </dev/tty
}

# -----------------------------------------------------------------------------
# File-backed Ctrl-I toggle (Termux-safe)
# - fzf reads initial list from stdin
# - Ctrl-I reloads from one of two precomputed files
# -----------------------------------------------------------------------------
run_fzf_toggle_files() {
  local query="$1"; shift
  local preview="$1"; shift
  local delimiter="$1"; shift
  local with_nth="$1"; shift
  local file_all="$1"; shift
  local file_hide="$1"; shift

  local st
  st="$(mktemp "${TMPDIR:-/tmp}/pkgsearch.hide.XXXXXX")" || return 1
  printf "0" >"$st"

  # POSIX-sh compatible bind (fzf executes binds via /bin/sh -c)
  local bind_toggle
  bind_toggle="ctrl-i:execute-silent(if [ \"\$(cat \"$st\")\" = 1 ]; then echo 0 >\"$st\"; else echo 1 >\"$st\"; fi)+reload(sh -c 'if [ \"\$(cat \"$st\")\" = 1 ]; then cat \"$file_hide\"; else cat \"$file_all\"; fi')"

  local out
  out="$(
    fzf --query="$query" \
        --delimiter="$delimiter" \
        --with-nth="$with_nth" \
        --preview="$preview" \
        --bind="$bind_toggle" \
        "$@"
  )"

  rm -f "$st" 2>/dev/null || true
  printf '%s' "$out"
}

# -----------------------------------------------------------------------------
# APT list (TAB-delimited):
#   col1: status marker (colored)  "[i]" or spaces
#   col2: raw package name         (NO color)  <-- preview/install
#   col3: pretty line (colored pkg + desc)
# -----------------------------------------------------------------------------
apt_list_annotated() {
  local hide_installed=0
  [[ $1 == "--hide-installed" ]] && hide_installed=1

  has dpkg-query apt-cache gawk || return 1

  local installed
  installed="$(dpkg-query -W -f='${binary:Package}\n' 2>/dev/null || true)"

  apt-cache search '.*' 2>/dev/null | sort |
    gawk -v green="$c_green" -v yellow="$c_yellow" -v reset="$c_reset" \
         -v installed_list="$installed" -v hide="$hide_installed" '
      BEGIN {
        n = split(installed_list, a, "\n");
        for (i = 1; i <= n; i++) if (a[i] != "") inst[a[i]] = 1;
      }
      {
        pkg = $1;
        $1 = ""; sub(/^ +/, "", $0);
        sub(/^- +/, "", $0);

        is_inst = (inst[pkg] ? 1 : 0);
        if (hide && is_inst) next;

        status = (is_inst ? yellow "[i]" reset : "   ");
        pretty = green pkg reset " - " $0;

        print status "\t" pkg "\t" pretty;
      }
    '
}

apt_pick_and_install() {
  local query="$1"
  local installer_prefix="$2"   # "" or "sudo "
  local installer_bin="$3"      # apt / apt-get / aptitude / pkg
  local cmd="${installer_prefix}${installer_bin} install"

  local f_all f_hide
  f_all="$(mktemp "${TMPDIR:-/tmp}/pkgsearch.apt.all.XXXXXX")" || return 1
  f_hide="$(mktemp "${TMPDIR:-/tmp}/pkgsearch.apt.hide.XXXXXX")" || { rm -f "$f_all"; return 1; }

  apt_list_annotated >"$f_all"
  apt_list_annotated --hide-installed >"$f_hide"

  local picked
  picked="$(
    cat "$f_all" |
      run_fzf_toggle_files "$query" \
        'apt-cache show {2}' \
        $'\t' \
        '1,3' \
        "$f_all" \
        "$f_hide"
  )"

  rm -f "$f_all" "$f_hide" 2>/dev/null || true

  [[ -n "$picked" ]] || return 0

  printf '%s\n' "$picked" |
    cut -f2 |
    install "$cmd"
}

# -----------------------------------------------------------------------------
# PACMAN list (TAB-delimited):
#   col1: status marker (colored)
#   col2: repo (colored)
#   col3: raw package name (NO color) <-- preview/install
#   col4: info/version/etc
#   col5: description
# -----------------------------------------------------------------------------
pacman_search_list() {
  local search_cmd="$1"     # pacman / paru / yay / etc
  local query="$2"
  local hide_installed=0
  [[ $3 == "--hide-installed" ]] && hide_installed=1

  has pacman gawk || return 1

  local installed
  installed="$(pacman -Qq 2>/dev/null || true)"

  $search_cmd -Ss "${query:-}" 2>/dev/null |
    gawk -v blue="$c_blue" -v yellow="$c_yellow" -v reset="$c_reset" \
         -v installed_list="$installed" -v hide="$hide_installed" '
      BEGIN {
        n = split(installed_list, a, "\n");
        for (i = 1; i <= n; i++) if (a[i] != "") inst[a[i]] = 1;
      }
      {
        header = $0;
        if (getline descr <= 0) descr = "";

        repo = gensub(/\/.*/, "", 1, $1);
        name = gensub(/.*\//, "", 1, $1);

        is_inst = (inst[name] ? 1 : 0);
        if (hide && is_inst) next;

        status = (is_inst ? yellow "[i]" reset : "   ");
        repo_c = blue "[" repo "]" reset;

        info = gensub(/[^ ]* /, "", 1, header);
        sub(/^[[:space:]]+/, "", descr);

        print status "\t" repo_c "\t" name "\t" info "\t" descr;
      }
    '
}

pacman_pick_and_install() {
  local query="$1"
  local search_cmd="$2"          # pacman / paru / yay ...
  local preview_cmd="$3"         # e.g. "pacman -Si {3}" or "yay -Si {3}"
  local install_cmd="$4"         # e.g. "sudo pacman -S" or "yay -S"

  local f_all f_hide
  f_all="$(mktemp "${TMPDIR:-/tmp}/pkgsearch.pac.all.XXXXXX")" || return 1
  f_hide="$(mktemp "${TMPDIR:-/tmp}/pkgsearch.pac.hide.XXXXXX")" || { rm -f "$f_all"; return 1; }

  pacman_search_list "$search_cmd" "$query" >"$f_all"
  pacman_search_list "$search_cmd" "$query" --hide-installed >"$f_hide"

  local picked
  picked="$(
    cat "$f_all" |
      run_fzf_toggle_files "$query" \
        "$preview_cmd" \
        $'\t' \
        '1,2,3,4,5' \
        "$f_all" \
        "$f_hide"
  )"

  rm -f "$f_all" "$f_hide" 2>/dev/null || true

  [[ -n "$picked" ]] || return 0

  printf '%s\n' "$picked" |
    cut -f3 |
    install "$install_cmd"
}

# -----------------------------------------------------------------------------
# Distros
# -----------------------------------------------------------------------------
termux_apt() {
  local bin
  bin="$(select_from 'pkg' 'apt' 'apt-get')" || die "no apt-based installer found (pkg/apt/apt-get)"
  apt_pick_and_install "$1" "" "$bin"
}

termux_pacman() {
  has pacman fzf gawk || die "missing deps for pacman: pacman/fzf/gawk"
  pacman_pick_and_install "$1" "pacman" 'pacman -Si {3}' 'pacman -S'
}

termux() {
  local pm="${TERMUX_APP_PACKAGE_MANAGER:-}"
  pm="${pm,,}"

  case "$pm" in
    pacman*) termux_pacman "$1" ;;
    apt*|'') termux_apt "$1" ;;
    *)
      if command -v pacman &>/dev/null; then termux_pacman "$1"; else termux_apt "$1"; fi
      ;;
  esac
}

debian() {
  local bin
  bin="$(select_from 'apt' 'aptitude' 'apt-get')" || die "no apt-based installer found (apt/aptitude/apt-get)"
  apt_pick_and_install "$1" "sudo " "$bin"
}

arch() {
  has fzf gawk pacman || die "missing deps: fzf/gawk/pacman"

  local search
  search='pacman'
  [[ -n "$1" ]] && search="$(select_from 'paru' 'yay' 'pacaur' 'trizen' 'yaourt' 'packer' 'apacman' 'pacman')"

  if [[ "$search" == "pacman" ]]; then
    pacman_pick_and_install "$1" "pacman" 'pacman -Si {3}' 'sudo pacman -S'
  else
    pacman_pick_and_install "$1" "$search" "$search -Si {3}" "$search -S"
  fi
}

void() {
  local package_list packagename='{ sub(/-[^\-]*$/, "", $2); print $2 }'
  package_list=$(xbps-query -Rs '' | sort)
  fzf --preview="p=\$(awk \"$packagename\" <<< {}); xbps-query -Rx \$p" \
    --query="$1" <<<"$package_list" |
    awk "$packagename" |
    install 'xbps-install -S'
}

fedora() {
  fzf --query="$*" --preview='p={}; p="${p%% *}"; dnf -q info "${p%.*}"' \
    < <(dnf -qC repoquery --qf "${c_green}%{name} ${c_reset} - %{summary}" \*) |
    awk '{ package=$1; sub(/\.\S+/, "", package); print package }' |
    install 'sudo dnf install'
}

# -----------------------------------------------------------------------------
# Args
# -----------------------------------------------------------------------------
while true; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -p|--preview) preview_pos="$2"; shift 2 ;;
    *) break ;;
  esac
done

has -v fzf gawk || die "missing deps: fzf and/or gawk"

request="$*"

if [[ -r /etc/os-release ]]; then
  distro=$(awk -F'=' '"NAME" == $1 { gsub("\"", "", $2); print tolower($2); }' /etc/os-release)
  distro="${distro%% *}"
elif [[ -r "$TERMUX__PREFIX/etc/os-release" ]]; then
  distro=$(awk -F'=' '"NAME" == $1 { gsub("\"", "", $2); print tolower($2); }' "$TERMUX__PREFIX/etc/os-release")
  distro="${distro%% *}"
fi

case "$distro" in
  debian|ubuntu) debian "$request" ;;
  arch) arch "$request" ;;
  void) void "$request" ;;
  fedora) fedora "$request" ;;
  termux) termux "$request" ;;
  *) die 'unknown distro :(' ;;
esac