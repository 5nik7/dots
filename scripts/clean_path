#!/usr/bin/env bash

main() {
  local old_path="${PATH:-}"
  local new_path=""
  local entry
  local IFS=:
  declare -A seen

  for entry in $old_path; do
    [[ -z "$entry" ]] && continue
    [[ -n "${seen[$entry]}" ]] && continue
    seen["$entry"]=1

    if [[ -d "$entry" ]]; then
      if [[ -z "$new_path" ]]; then
        new_path="$entry"
      else
        new_path="$new_path:$entry"
      fi
    else
      printf 'Not a Directory: %s\n' "$entry" >&2
    fi
  done

  echo "$new_path"
}

main
