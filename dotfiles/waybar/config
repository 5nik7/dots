{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [
        "custom/launcher",
        "sway/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "memory",
        "custom/separator",
        "cpu",
        "custom/separator",
        "clock"
    ],
    "fixed-center": true,

    "custom/launcher": {
    "format": " 󰚌 ",
    "on-click": "~/.config/rofi/launcher.sh",
    "tooltip": false
    },

    "clock": {
        "interval": 1,
        "format": " {:%a %Y.%m.%d %H:%M}",
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{icon}"
    },

     "memory": {
        "interval": 10,
        "format": " {}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

     "cpu": {
        "interval": 10,
        "format": " {usage}%",
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "tray": {
        "icon-size": 16,
        "spacing": 5
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    }
}
