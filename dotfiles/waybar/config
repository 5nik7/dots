{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [
        "sway/workspaces",
        "way/mode"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "clock"
    ],
    "fixed-center": true,


    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}"
    },

    "sway/mode": {
        "format": "<span style=\"normal\">{}</span>",
        "on-click": "swaymsg 'mode \"resize\"'"
    },

    "clock": {
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% "
    },
    "memory": {
        "format": "{}% mem"
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    }
}

