#!/usr/bin/env zsh

export DOTS="${DOTS:-$HOME/dots}"
export DOTBIN="${DOTBIN:-$DOTS/bin}"
export DOTFUNC="${DOTFUNC:-$DOTS/functions}"
export DOTSCRIPTS="${DOTSCRIPTS:-$DOTS/scripts}"
export DOTFILES="${DOTFILES:-$DOTS/configs}"
export DOTCONFIG="${DOTFILES:-$DOTS/configs}"
export DOTSHHHH="${DOTSHHHH:-DOTS/secrets}"
export DOTLOCAL="${DOTLOCAL:-$DOTS/local}"
export DOTLOCALBIN="${DOTLOCALBIN:-$DOTSLOCAL/bin}"
export DOTLOCALSHARE="${DOTLOCALSHARE:-$DOTSLOCAL/share}"

declare -xgA dot
declare -x dot[root]="${DOTS:-$HOME/dots}"
declare -x dot[bin]="${DOTBIN:-$DOTS/bin}"
declare -x dot[functions]="${DOTFUNC:-$DOTS/functions}"
declare -x dot[scripts]="${DOTSCRIPTS:-$DOTS/scripts}"
declare -x dot[files]="${DOTFILES:-$DOTS/configs}"
declare -x dot[configs]="${DOTFILES:-$DOTS/configs}"
declare -x dot[local]="${DOTLOCAL:-$DOTS/local}"
declare -x dot[localbin]="${DOTLOCALBIN:-$DOTS/local/bin}"
declare -x dot[localshare]="${DOTLOCALSHARE:-$DOTS/local}/share"
declare -x dot[secrets]="${DOTSHHHH:-DOTS/secrets}"
declare -x dot[walls]="$DOTS/walls"
declare -x dot[fonts]="$DOTS/fonts"

dotpaths=($dot[bin] $dot[scripts] $dot[functions] $dot[localbin])

for dotpath in "${dotpaths[@]}";do
  prepath "$dotpath"
done

fpath=("${dotpaths[@]}" $fpath)

